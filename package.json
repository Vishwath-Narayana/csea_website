{
  "name": "csea-digital-platform",
  "version": "1.0.0",
  "private": true,
  "description": "CSEA Digital Platform Phase 1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "verify": "turbo run typecheck lint build",
    "verify:e2e": "pnpm --filter @csea/e2e test"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  }
}
