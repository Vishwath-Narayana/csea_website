---
import Layout from '../../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
const filter = Astro.url.searchParams.get('filter') || 'all';
const now = new Date();

let allEvents: any[] = [];
try {
  const res = await fetch(`${API_URL}/api/v1/events`);
  if (res.ok) {
    const data = await res.json();
    allEvents = data.data || [];
  }
} catch (e) {
  console.error("Failed to fetch events", e);
}

let filteredEvents = allEvents;
if (filter === 'upcoming') {
  filteredEvents = allEvents.filter((e: any) => new Date(e.startDate) > now);
} else if (filter === 'registration-open') {
  filteredEvents = allEvents.filter((e: any) => e.registrationEnabled && e.registrationUrl);
} else if (filter === 'past') {
  filteredEvents = allEvents.filter((e: any) => new Date(e.endDate) < now);
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
};

const activeClass = 'text-[13px] font-semibold text-white bg-accent px-4 py-2 rounded-md whitespace-nowrap shadow-soft no-underline';
const inactiveClass = 'text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline';
---

<Layout title="Upcoming Events & Timeline | CSEA">

  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="0" y1="20" x2="100" y2="80" stroke="var(--accent)" stroke-width="0.3" />
      </svg>
    </div>

    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">

      <!-- Header -->
      <div class="mb-20 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // PROGRAM TIMELINE & SUMMITS
        </div>
        <h1 class="text-display-lg text-foreground mb-4">Timeline.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Discover hackathons, guest seminars, panel sessions, and community orientation gatherings. Save the dates.
        </p>
      </div>

      <!-- Filter buttons -->
      <div class="flex items-center gap-3 border-b border-border pb-6 mb-16 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11px] font-mono text-foreground-muted tracking-wider uppercase mr-4 whitespace-nowrap">// CHRONOLOGY</span>
        <a href="/events" class={filter === 'all' ? activeClass : inactiveClass}>All Events</a>
        <a href="/events?filter=upcoming" class={filter === 'upcoming' ? activeClass : inactiveClass}>Upcoming</a>
        <a href="/events?filter=registration-open" class={filter === 'registration-open' ? activeClass : inactiveClass}>Registration Open</a>
        <a href="/events?filter=past" class={filter === 'past' ? activeClass : inactiveClass}>Past Archives</a>
      </div>

      <!-- Event Cards -->
      <div class="reveal" style="transition-delay: 100ms;">
        {filteredEvents.length === 0 ? (
          <div class="text-center py-20 text-foreground-secondary">
            <p>No events available for this filter.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {filteredEvents.map((event: any) => (
              <div class="group bg-surface border border-border hover:border-accent/40 rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300 flex flex-col">
                <div class="flex-1 flex flex-col p-5">
                  <div class="flex items-center justify-between mb-3">
                    {event.eventType ? (
                      <span class="text-[11px] font-mono text-accent font-bold tracking-wider uppercase">{event.eventType}</span>
                    ) : <span />}
                    <span class="text-[12px] text-foreground-muted ml-auto">{formatDate(event.startDate)}</span>
                  </div>

                  <h3 class="text-h3 mb-2 leading-snug line-clamp-2">
                    {event.title}
                  </h3>

                  {event.shortDescription && (
                    <p class="text-[13.5px] text-foreground-secondary leading-relaxed mb-4 flex-1 line-clamp-3">
                      {event.shortDescription}
                    </p>
                  )}

                  {event.venue && (
                    <p class="text-[12px] text-foreground-muted mb-4 flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                      {event.venue}
                    </p>
                  )}

                  <div class="border-t border-border pt-4 mt-auto">
                    {(event.registrationEnabled && event.registrationUrl) ? (
                      <a
                        href={event.registrationUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center text-[12px] font-medium text-foreground group-hover:text-accent hover:text-accent transition-colors no-underline"
                      >
                        Register Now →
                      </a>
                    ) : (
                      <a
                        href={`/events/${event.slug}`}
                        class="inline-flex items-center text-[12px] font-medium text-foreground-muted hover:text-foreground transition-colors no-underline"
                      >
                        View Details →
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
