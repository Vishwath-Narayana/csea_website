---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Upcoming Events & Timeline | CSEA">
  
  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 glow-ambient opacity-20 pointer-events-none"></div>
    
    <div class="max-w-content mx-auto px-4 lg:px-8 relative z-10">
      
      <!-- Header -->
      <div class="mb-20 reveal">
        <div class="text-[11px] font-mono text-accent font-semibold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span> PROGRAM TIMELINE & SUMMITS
        </div>
        <h1 class="text-display-lg text-foreground mb-4">Timeline.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Discover hackathons, guest seminars, panel sessions, and community orientation gatherings. Save the dates.
        </p>
      </div>

      <!-- Timeline filters -->
      <div class="flex gap-3 border-b border-border pb-6 mb-20 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11.5px] font-mono text-foreground-subtle tracking-wider uppercase mr-2">// CHRONOLOGY</span>
        <a href="#" class="text-[13px] font-semibold text-white bg-accent px-4 py-1.5 rounded-lg whitespace-nowrap shadow-soft no-underline">All Scheduled</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface/50 border border-border px-4 py-1.5 rounded-lg whitespace-nowrap transition-colors no-underline">Upcoming</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface/50 border border-border px-4 py-1.5 rounded-lg whitespace-nowrap transition-colors no-underline">Registration Open</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface/50 border border-border px-4 py-1.5 rounded-lg whitespace-nowrap transition-colors no-underline">Past Archives</a>
      </div>

      <!-- Timeline Path Container -->
      <div class="relative reveal" style="transition-delay: 100ms;">
        
        <!-- CSEA Thread Timeline Line -->
        <div class="absolute left-6 lg:left-12 top-4 bottom-0 w-[2px] bg-accent/20 hidden sm:block">
          <!-- Pulse line effect -->
          <div class="absolute top-0 w-full h-32 bg-gradient-to-b from-accent to-transparent"></div>
        </div>

        <div class="flex flex-col gap-16">
          
          <!-- Card 1: Featured Orientation (Active) -->
          <div class="relative flex flex-col sm:flex-row gap-8 lg:gap-16 group">
            
            <!-- Timeline Node Badge -->
            <div class="hidden sm:flex flex-shrink-0 w-12 lg:w-24 justify-center pt-8">
              <div class="relative z-10 w-4 h-4 rounded-full bg-accent border-4 border-canvas shadow-soft flex items-center justify-center">
                <div class="absolute inset-0 rounded-full bg-accent animate-ping opacity-60"></div>
              </div>
            </div>

            <div class="flex-1 bg-surface border border-border-strong/60 rounded-2xl overflow-hidden shadow-medium hover:border-accent hover:shadow-strong transition-all duration-300">
              <div class="grid grid-cols-1 lg:grid-cols-12">
                
                <!-- Left media section -->
                <div class="lg:col-span-5 aspect-video lg:aspect-auto relative bg-surface-secondary border-r border-border">
                  <div class="absolute inset-0 img-placeholder">Orientation Graphic</div>
                  <div class="absolute top-4 left-4 badge badge-accent shadow-soft bg-surface/90 backdrop-blur-md">Registration Open</div>
                </div>
                
                <!-- Right details -->
                <div class="lg:col-span-7 p-6 lg:p-10 flex flex-col justify-center">
                  <div class="flex items-center gap-4 text-[12.5px] text-foreground-muted mb-4 font-mono">
                    <span class="text-accent font-bold">15 AUG 2026</span>
                    <span>09:00 AM</span>
                    <span>KITSW Main Auditorium</span>
                  </div>
                  <h2 class="text-h1 mb-4 group-hover:text-accent transition-colors leading-tight">
                    CSEA Orientation 2026
                  </h2>
                  <p class="text-body-sm text-foreground-secondary mb-6 leading-relaxed">
                    Join us to discover how the association operates, the projects we are launching, and how you can become a core contributor this academic year. Mandatory for all new CS students.
                  </p>
                  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-border mt-2">
                    <span class="text-[13px] text-success font-semibold flex items-center gap-2">
                      <span class="w-2 h-2 rounded-full bg-success"></span>
                      148 Registered (37% Cap)
                    </span>
                    <a href="/events/orientation-26" class="btn btn-primary text-[12.5px] px-6 py-2">
                      Get Pass &rarr;
                    </a>
                  </div>
                </div>

              </div>
            </div>

          </div>

          <!-- Card 2: Tech Talk -->
          <div class="relative flex flex-col sm:flex-row gap-8 lg:gap-16 group">
            
            <!-- Timeline Node Badge -->
            <div class="hidden sm:flex flex-shrink-0 w-12 lg:w-24 justify-center pt-6">
              <div class="z-10 w-3 h-3 rounded-full bg-surface border-2 border-border-strong/80 shadow-soft"></div>
            </div>

            <div class="flex-1 bg-surface/50 border border-border rounded-2xl p-6 lg:p-8 hover:border-border-strong transition-colors duration-200">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                  <div class="flex items-center gap-3 text-[12px] font-mono text-foreground-muted mb-2">
                    <span class="text-foreground font-semibold">22 AUG 2026</span>
                    <span>Seminar Hall</span>
                  </div>
                  <h3 class="text-h2 text-foreground group-hover:text-accent transition-colors leading-snug">
                    Tech Talk: Distributed Systems
                  </h3>
                  <p class="text-body-sm text-foreground-secondary leading-relaxed mt-2 max-w-2xl">
                    An introduction to building scalable backend systems, featuring a guest lecture from our alumni network.
                  </p>
                </div>
                <div class="flex-shrink-0">
                  <a href="/events/tech-talk-1" class="btn btn-outline text-[12px] px-4.5 py-2">
                    Event Details
                  </a>
                </div>
              </div>
            </div>

          </div>

          <!-- Card 3: Hackathon -->
          <div class="relative flex flex-col sm:flex-row gap-8 lg:gap-16 group">
            
            <!-- Timeline Node Badge -->
            <div class="hidden sm:flex flex-shrink-0 w-12 lg:w-24 justify-center pt-6">
              <div class="z-10 w-3 h-3 rounded-full bg-surface border-2 border-border-strong/80 shadow-soft"></div>
            </div>

            <div class="flex-1 bg-surface/50 border border-border rounded-2xl p-6 lg:p-8 hover:border-border-strong transition-colors duration-200">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                  <div class="flex items-center gap-3 text-[12px] font-mono text-foreground-muted mb-2">
                    <span class="text-foreground font-semibold">10 SEP 2026</span>
                    <span>Innovation Lab</span>
                  </div>
                  <h3 class="text-h2 text-foreground group-hover:text-accent transition-colors leading-snug">
                    Autumn Hackathon 2026
                  </h3>
                  <p class="text-body-sm text-foreground-secondary leading-relaxed mt-2 max-w-2xl">
                    A 24-hour coding sprint focused on building internal tools for the campus. Food and drinks provided.
                  </p>
                </div>
                <div class="flex-shrink-0">
                  <a href="/events/hackathon" class="btn btn-outline text-[12px] px-4.5 py-2">
                    Event Details
                  </a>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
