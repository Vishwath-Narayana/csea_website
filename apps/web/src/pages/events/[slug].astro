---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'orientation-26' } },
    { params: { slug: 'tech-talk-1' } },
    { params: { slug: 'hackathon' } },
  ];
}
---

<Layout title="CSEA Orientation 2026 | CSEA">
  
  <!-- Hero Section -->
  <section class="pt-28 pb-16 bg-canvas bg-grid-blueprint border-b border-border relative">
    <div class="absolute inset-0 glow-ambient opacity-20 pointer-events-none"></div>
    
    <div class="max-w-content mx-auto px-4 lg:px-8 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Event Hero Details (Left Column) -->
      <div class="lg:col-span-7 reveal">
        <div class="flex items-center gap-3.5 mb-6">
          <span class="badge badge-accent">Registration Open</span>
          <span class="text-[12px] font-mono text-accent font-semibold tracking-wider">// 15 AUG 2026</span>
        </div>
        
        <h1 class="text-display-md mb-6 leading-tight text-foreground">CSEA Orientation 2026</h1>
        <p class="text-body-lg text-foreground-secondary mb-8 max-w-xl leading-relaxed">
          Join us to discover how the association operates, the projects we are launching, and how you can become a core contributor this academic year. Mandatory for all new CS students.
        </p>
        
        <!-- Quick Specs Table -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 border-y border-border py-6 mb-8 bg-surface/35 backdrop-blur-sm px-4 rounded-xl">
          <div>
            <div class="text-[10px] font-mono tracking-wider uppercase text-foreground-muted mb-1">Date</div>
            <div class="text-[13.5px] font-bold text-foreground">Aug 15, 2026</div>
          </div>
          <div>
            <div class="text-[10px] font-mono tracking-wider uppercase text-foreground-muted mb-1">Time</div>
            <div class="text-[13.5px] font-bold text-foreground">09:00 AM</div>
          </div>
          <div>
            <div class="text-[10px] font-mono tracking-wider uppercase text-foreground-muted mb-1">Venue</div>
            <div class="text-[13.5px] font-bold text-foreground">Main Aud.</div>
          </div>
          <div>
            <div class="text-[10px] font-mono tracking-wider uppercase text-foreground-muted mb-1">Capacity</div>
            <div class="text-[13.5px] font-bold text-foreground">400 Seats</div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
          <a href="/portal/login" class="btn btn-primary text-center px-8 py-3 rounded-lg font-semibold">
            Register for Pass
          </a>
          <button 
            class="btn btn-outline text-center px-8 py-3 rounded-lg font-semibold"
            onclick="alert('Event added to calendar!');"
          >
            Add to Calendar
          </button>
        </div>
      </div>

      <!-- Event Hero Image Frame (Right Column) -->
      <div class="lg:col-span-5 reveal" style="transition-delay: 100ms;">
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden bg-surface border border-border-strong/60 p-3 shadow-medium">
          <div class="img-placeholder w-full h-full rounded-xl">Orientation Session Cover Graphic</div>
        </div>
      </div>

    </div>
  </section>

  <!-- Editorial Layout for description and schedule -->
  <section class="py-24 bg-surface">
    <div class="max-w-content mx-auto px-4 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Content: Schedule & About -->
      <div class="lg:col-span-8 text-body text-foreground-secondary leading-relaxed flex flex-col gap-8 reveal">
        <div>
          <h2 class="text-h2 text-foreground mb-4">About this event</h2>
          <p class="mb-4">
            The annual CSEA orientation is the official kickoff for the new academic year. This event is designed to introduce new students to the Computer Science & Engineering Association, our core committee, and the various technical initiatives running on campus.
          </p>
          <p>
            We will be discussing upcoming projects, how to apply for the technical teams, and previewing the hackathon schedule for the semester.
          </p>
        </div>

        <div>
          <h3 class="text-h3 text-foreground mb-4">Schedule of Events</h3>
          
          <div class="flex flex-col border border-border rounded-xl bg-canvas/30 overflow-hidden">
            <div class="flex items-center gap-6 p-4.5 border-b border-border bg-surface/50">
              <div class="font-mono text-[13.5px] text-accent font-semibold w-24">09:00 AM</div>
              <div class="text-[14px] text-foreground font-medium">Doors Open & Registration Seating</div>
            </div>
            <div class="flex items-center gap-6 p-4.5 border-b border-border bg-surface/50">
              <div class="font-mono text-[13.5px] text-accent font-semibold w-24">09:30 AM</div>
              <div class="text-[14px] text-foreground font-medium">Keynote Address: CSEA Vision for 2026</div>
            </div>
            <div class="flex items-center gap-6 p-4.5 border-b border-border bg-surface/50">
              <div class="font-mono text-[13.5px] text-accent font-semibold w-24">10:30 AM</div>
              <div class="text-[14px] text-foreground font-medium">Systems Development Presentations & Showcases</div>
            </div>
            <div class="flex items-center gap-6 p-4.5 bg-surface/50">
              <div class="font-mono text-[13.5px] text-accent font-semibold w-24">11:30 AM</div>
              <div class="text-[14px] text-foreground font-medium">Q&A panel, networking and tea session</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Content: Sidebar Details -->
      <div class="lg:col-span-4 flex flex-col gap-8 reveal" style="transition-delay: 100ms;">
        
        <!-- Registration Sidebar Card -->
        <div class="bg-canvas border border-border-strong/60 rounded-2xl p-6 lg:p-8">
          <h3 class="text-[14.5px] font-bold text-foreground mb-5">Registration Details</h3>
          
          <div class="flex flex-col gap-4 text-[13.5px] mb-6">
            <div class="flex justify-between items-center pb-2.5 border-b border-border">
              <span class="text-foreground-secondary">Status</span>
              <span class="font-semibold text-success">Open & Active</span>
            </div>
            <div class="flex justify-between items-center pb-2.5 border-b border-border">
              <span class="text-foreground-secondary">Deadline</span>
              <span class="font-mono text-foreground font-medium">Aug 14, 11:59 PM</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-foreground-secondary">Eligibility</span>
              <span class="font-semibold text-foreground">All CS Students</span>
            </div>
          </div>
          
          <div class="w-full bg-surface border border-border rounded-full h-2 mb-2.5 overflow-hidden">
            <div class="bg-accent h-full rounded-full" style="width: 37%"></div>
          </div>
          <div class="text-[11.5px] text-foreground-muted flex justify-between font-mono">
            <span>148 REGISTERED</span>
            <span>400 CAPACITY</span>
          </div>
        </div>

        <!-- Organizer Card -->
        <div class="bg-canvas border border-border rounded-2xl p-6 lg:p-8">
          <h3 class="text-[14.5px] font-bold text-foreground mb-4">Organizer</h3>
          
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-accent/5 border border-accent/20 flex items-center justify-center font-display font-bold text-accent">OC</div>
            <div>
              <div class="text-[14px] font-bold text-foreground leading-tight">Orientation Board</div>
              <div class="text-[12px] text-foreground-muted">CSEA Executive Committee</div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

</Layout>
