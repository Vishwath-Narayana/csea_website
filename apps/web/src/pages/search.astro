---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search Platform | CSEA">
  
  <div class="min-h-[80vh] pt-28 pb-32 bg-canvas bg-grid-blueprint relative">
    <div class="absolute inset-0 glow-ambient opacity-20 pointer-events-none"></div>
    
    <div class="max-w-editorial mx-auto px-4 lg:px-8 relative z-10">
      
      <!-- Command Input Wrapper -->
      <div class="mb-12 reveal">
        <div class="relative shadow-strong rounded-2xl bg-surface border border-border-strong overflow-hidden focus-within:ring-2 focus-within:ring-accent focus-within:border-accent transition-all duration-300">
          <div class="absolute inset-y-0 left-0 pl-4.5 flex items-center pointer-events-none text-foreground-muted">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <input 
            type="text" 
            placeholder="Search Journal, Events, Projects..." 
            class="w-full bg-transparent border-none pl-12.5 pr-16 py-4.5 text-[17px] text-foreground focus:outline-none placeholder-foreground-muted"
            autofocus
          />
          <div class="absolute inset-y-0 right-0 pr-4 flex items-center gap-1">
            <kbd class="hidden sm:inline-block font-mono text-[9px] px-1.5 py-0.5 rounded-[4px] border border-border bg-canvas shadow-sm text-foreground-muted">ESC</kbd>
          </div>
        </div>
      </div>

      <!-- Quick results / Category suggestions -->
      <div class="reveal flex flex-col gap-8" style="transition-delay: 50ms;">
        
        <div>
          <div class="text-[10px] font-mono font-semibold tracking-wider text-foreground-muted uppercase mb-4 border-b border-border pb-2">
            Suggested Pages & Resources
          </div>
          
          <ul class="flex flex-col gap-2 list-none p-0">
            <li>
              <a href="/projects/platform" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-surface border border-transparent hover:border-border-strong/30 text-foreground no-underline group transition-all duration-200">
                <div class="w-8 h-8 rounded-lg bg-accent/5 flex items-center justify-center text-accent">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                </div>
                <div class="flex flex-col">
                  <span class="text-[14px] font-semibold group-hover:text-accent transition-colors">CSEA Digital Platform</span>
                  <span class="text-[12px] text-foreground-secondary mt-0.5">Software systems development details</span>
                </div>
                <span class="ml-auto text-[9px] font-mono text-foreground-muted tracking-wider uppercase bg-surface-secondary px-2 py-0.5 rounded-sm">Project</span>
              </a>
            </li>
            
            <li>
              <a href="/events/orientation-26" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-surface border border-transparent hover:border-border-strong/30 text-foreground no-underline group transition-all duration-200">
                <div class="w-8 h-8 rounded-lg bg-accent/5 flex items-center justify-center text-accent">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                </div>
                <div class="flex flex-col">
                  <span class="text-[14px] font-semibold group-hover:text-accent transition-colors">CSEA Orientation 2026</span>
                  <span class="text-[12px] text-foreground-secondary mt-0.5">Upcoming welcoming event and committee introductions</span>
                </div>
                <span class="ml-auto text-[9px] font-mono text-foreground-muted tracking-wider uppercase bg-surface-secondary px-2 py-0.5 rounded-sm">Event</span>
              </a>
            </li>
            
            <li>
              <a href="/journal/tech-stack" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-surface border border-transparent hover:border-border-strong/30 text-foreground no-underline group transition-all duration-200">
                <div class="w-8 h-8 rounded-lg bg-accent/5 flex items-center justify-center text-accent">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </div>
                <div class="flex flex-col">
                  <span class="text-[14px] font-semibold group-hover:text-accent transition-colors">Architecting the New Platform</span>
                  <span class="text-[12px] text-foreground-secondary mt-0.5">Technical writeup regarding Astro, React, and Fastify implementation</span>
                </div>
                <span class="ml-auto text-[9px] font-mono text-foreground-muted tracking-wider uppercase bg-surface-secondary px-2 py-0.5 rounded-sm">Journal</span>
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>

</Layout>
