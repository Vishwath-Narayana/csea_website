---
import Layout from '../layouts/Layout.astro';

const advisors = [
  { name: 'Dr. V. Shankar', role: 'Professor & Head, CSE', details: 'Faculty Advisor' },
  { name: 'Dr. S. Narasimha Reddy', role: 'Associate Professor, CSE', details: 'Co-coordinator' }
];

const committee = [
  { name: 'A. Sathvik', role: 'President', year: 'IV/IV B.Tech', bio: 'Directing overall executive strategy and external coordination.' },
  { name: 'K. Shruti', role: 'Vice President', year: 'IV/IV B.Tech', bio: 'Managing student outreach programs and internal operational synergy.' },
  { name: 'P. Rohit', role: 'General Secretary', year: 'IV/IV B.Tech', bio: 'Overseeing all event planning and treasury audit procedures.' },
  { name: 'M. Nihal', role: 'Joint Secretary', year: 'III/IV B.Tech', bio: 'Assisting in operations and coordinating execution teams.' }
];

const leads = [
  { name: 'G. Sharan', role: 'Technical Operations Lead', year: 'III/IV B.Tech', details: 'Full-stack developments & core infra' },
  { name: 'S. Neha', role: 'Editorial Board Lead', year: 'III/IV B.Tech', details: 'Technical publishing & documentation' },
  { name: 'V. Rithvik', role: 'Public Relations Lead', year: 'III/IV B.Tech', details: 'Alumni networks & company outreach' }
];
---

<Layout title="Executive Board & Team | CSEA">
  
  <!-- Header -->
  <section class="pt-28 pb-20 bg-canvas bg-grid-blueprint relative border-b border-border overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none select-none opacity-20">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="100" y1="45" x2="0" y2="55" stroke="var(--accent)" stroke-width="0.3" stroke-dasharray="2 2" />
      </svg>
    </div>
    
    <div class="max-w-[1280px] mx-auto px-5 md:px-6 lg:px-8 relative z-10 text-center reveal">
      <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-4 flex items-center justify-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // STAFF & LEADER ROSTER
      </div>
      <h1 class="text-display-lg mb-6">The Committee.</h1>
      <p class="text-body-lg text-foreground-secondary max-w-2xl mx-auto">
        Meet the faculty advisors, student executive board, and technical division leads guiding CSEA operations at KITSW.
      </p>
    </div>
  </section>

  <!-- 1. Faculty Leadership -->
  <section class="py-24 bg-surface">
    <div class="max-w-[1280px] mx-auto px-5 md:px-6 lg:px-8 reveal">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 rounded bg-accent/10 border border-accent/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <h2 class="text-h2 text-foreground">Faculty Leadership</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {advisors.map(member => (
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 p-8 rounded-lg border border-border bg-canvas hover:shadow-soft transition-all duration-300 group">
            <div class="w-24 h-24 rounded-lg bg-surface-secondary border border-border flex items-center justify-center font-display font-semibold text-foreground-muted text-3xl flex-shrink-0 select-none overflow-hidden relative">
              <span class="relative z-10 group-hover:text-accent transition-colors duration-300">{member.name.split(' ').slice(-1)[0][0]}</span>
              <div class="absolute inset-0 bg-gradient-to-tr from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <div>
              <h3 class="text-[20px] font-bold text-foreground leading-tight mb-1 group-hover:text-accent transition-colors">{member.name}</h3>
              <p class="text-[14.5px] font-medium text-foreground-secondary mb-1.5">{member.role}</p>
              <span class="badge bg-surface-secondary text-foreground-muted border border-border font-medium tracking-wide">
                {member.details}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 2. Core Committee -->
  <section class="py-24 bg-surface-secondary border-t border-border">
    <div class="max-w-[1280px] mx-auto px-5 md:px-6 lg:px-8 reveal">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 rounded bg-accent/10 border border-accent/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </div>
        <h2 class="text-h2 text-foreground">Core Committee</h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {committee.map(member => (
          <div class="bg-surface border border-border rounded-lg p-6 flex flex-col group hover:border-accent/30 hover:shadow-soft transition-all duration-300">
            <div class="w-16 h-16 rounded-lg bg-canvas border border-border flex items-center justify-center font-display font-semibold text-foreground-muted text-xl mb-6 select-none group-hover:bg-accent/5 group-hover:text-accent group-hover:border-accent/20 transition-all duration-300">
              {member.name[0]}
            </div>
            <div class="flex-1">
              <h3 class="text-[18px] font-bold text-foreground group-hover:text-accent transition-colors leading-tight mb-1">{member.name}</h3>
              <div class="text-[13.5px] font-medium text-foreground-secondary mb-3">{member.role}</div>
              <p class="text-[13.5px] text-foreground-muted leading-relaxed mb-6">
                {member.bio}
              </p>
            </div>
            <div class="pt-4 border-t border-border text-[11px] font-mono text-foreground-subtle tracking-wider uppercase">
              {member.year}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Executives / Leads -->
  <section class="py-24 bg-surface border-t border-border">
    <div class="max-w-[1280px] mx-auto px-5 md:px-6 lg:px-8 reveal">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 rounded bg-accent/10 border border-accent/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        </div>
        <h2 class="text-h2 text-foreground">Executives & Leads</h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {leads.map(member => (
          <div class="p-5 rounded-lg border border-border bg-canvas flex items-center gap-5 hover:border-accent/30 hover:shadow-soft transition-all duration-300 group">
            <div class="w-12 h-12 rounded bg-surface border border-border flex items-center justify-center font-semibold text-foreground-muted select-none group-hover:bg-accent/5 group-hover:text-accent transition-colors duration-300">
              {member.name[0]}
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-foreground group-hover:text-accent transition-colors mb-0.5">{member.name}</h3>
              <div class="text-[13px] font-medium text-foreground-secondary">{member.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
