  <!-- Script for quote carousel -->
  <script>
    const quotes = [
      {
        quote: "CSEA is a lab where computer science is put to work. It bridges the gap between our classrooms and the dynamic infrastructure requirements of the industry.",
        author: "Dr. V. Shankar — Head, Department of CSE"
      },
      {
        quote: "Our squads do not make templates or build portfolio sites. We focus on architecting attendance registers, custom lab APIs, and publishing case studies.",
        author: "A. Sathvik — Student President"
      }
    ];

    let currentIndex = 0;
    const carousel = document.getElementById('voices-carousel');
    const dots = document.querySelectorAll('.voice-dot');
    const nextBtn = document.getElementById('voice-next');
    const prevBtn = document.getElementById('voice-prev');

    function updateQuote(idx) {
      if (carousel) {
        carousel.style.opacity = '0';
        setTimeout(() => {
          carousel.innerHTML = `
            <blockquote class="text-[28px] md:text-[36px] font-sans font-medium tracking-tight leading-snug text-dark-foreground mb-8 text-balance">
              "${quotes[idx].quote}"
            </blockquote>
            <cite class="not-italic font-mono text-sm text-accent uppercase">
              ${quotes[idx].author}
            </cite>
          `;
          dots.forEach((dot, dIdx) => {
            if (dIdx === idx) {
              dot.classList.remove('bg-dark-border');
              dot.classList.add('bg-accent');
            } else {
              dot.classList.remove('bg-accent');
              dot.classList.add('bg-dark-border');
            }
          });
          carousel.style.opacity = '1';
        }, 150);
      }
    }

    nextBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % quotes.length;
      updateQuote(currentIndex);
    });

    prevBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + quotes.length) % quotes.length;
      updateQuote(currentIndex);
    });
  </script>

