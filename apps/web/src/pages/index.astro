---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Computer Science & Engineering Association" hasBanner={true}>
  
  <!-- 1. LIVE ANNOUNCEMENT STRIP -->
  <div class="bg-accent text-white py-3 overflow-hidden border-b border-accent-hover relative z-20 mt-[-64px]">
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 flex items-center justify-between text-xs font-mono tracking-wider">
      <div class="flex items-center gap-3 animate-pulse">
        <span class="inline-block w-2 h-2 rounded-full bg-white"></span>
        <span class="font-bold">NEXT EVENT //</span>
        <span>CSEA Orientation 2026 &middot; August 15, 2026</span>
      </div>
      <a href="/events/orientation-26" class="hover:underline flex items-center gap-1 font-bold">
        REGISTER NOW <span class="text-sm leading-none">&rarr;</span>
      </a>
    </div>
  </div>

  <!-- 2. HERO SECTION -->
  <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-36 bg-canvas flex items-center overflow-hidden min-h-[85vh]">
    <!-- Network graphic backdrop (Subtle thread vectors) -->
    <div class="absolute inset-0 z-0 pointer-events-none select-none opacity-40">
      <svg class="w-full h-full" viewBox="0 0 1440 800" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- SVG Paths representing CSEA Thread -->
        <path id="hero-thread-1" d="M100,200 Q400,100 700,450 T1300,300" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="8 8" class="animate-thread-pulse" />
        <path id="hero-thread-2" d="M200,600 Q600,750 900,400 T1200,700" stroke="var(--accent)" stroke-width="1" stroke-opacity="0.3" stroke-linecap="round" />
        
        <!-- Node Coordinates & Labels -->
        <g transform="translate(700, 450)">
          <circle r="4" fill="var(--accent)" class="animate-ping" />
          <circle r="3" fill="var(--accent)" />
          <text x="12" y="4" fill="var(--foreground-muted)" font-family="monospace" font-size="10" tracking="0.1em">SYS_NODE_01 // WARANGAL</text>
        </g>
        <g transform="translate(100, 200)">
          <circle r="3" fill="var(--foreground-subtle)" />
        </g>
        <g transform="translate(1300, 300)">
          <circle r="3" fill="var(--accent)" />
        </g>
      </svg>
    </div>

    <!-- Hero container -->
    <div class="max-w-[1400px] w-full mx-auto px-5 md:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center relative z-10">
      
      <!-- Left Column: Typography & CTAs (7 Columns) -->
      <div class="lg:col-span-7 flex flex-col justify-center reveal">
        <div class="inline-flex items-center gap-2 mb-5">
          <span class="text-[11px] font-mono tracking-[0.15em] text-accent font-bold uppercase bg-accent-muted px-2.5 py-1 rounded-md">
            ESTD. 1998
          </span>
          <span class="text-[11px] font-mono tracking-[0.1em] text-foreground-muted uppercase">
            KITSW &middot; Dept of CSE
          </span>
        </div>
        
        <h1 class="text-display-xl text-foreground mb-8 text-balance">
          Where computer science becomes <span class="relative inline-block text-accent">community.<svg class="absolute left-0 bottom-[-4px] w-full h-[6px]" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0,5 Q50,9 100,5" stroke="var(--accent)" stroke-width="4" fill="none" stroke-linecap="round"></path></svg></span>
        </h1>
        
        <p class="text-body-lg text-foreground-secondary mb-10 max-w-[620px] leading-relaxed">
          We are the official student department body at Kakatiya Institute of Technology & Science, Warangal. CSEA bridges academic study and industry-level software engineering through collaborative squads, summits, and technical publishing.
        </p>
        
        <div class="flex flex-wrap gap-4 items-center">
          <a href="/about" class="btn btn-primary px-8 py-3.5 shadow-soft no-underline text-center">
            Explore CSEA
          </a>
          <a href="/events" class="btn btn-outline px-8 py-3.5 hover:bg-surface-secondary no-underline text-center">
            View Roadmaps &rarr;
          </a>
        </div>

        <!-- Network indicators -->
        <div class="grid grid-cols-4 gap-4 mt-16 pt-8 border-t border-border max-w-[500px]">
          <div class="flex flex-col">
            <span class="text-[10px] font-mono text-accent font-bold tracking-widest uppercase mb-1">01 / LEARN</span>
            <span class="text-xs text-foreground-secondary">Peer Cohorts</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[10px] font-mono text-accent font-bold tracking-widest uppercase mb-1">02 / BUILD</span>
            <span class="text-xs text-foreground-secondary">Local Squads</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[10px] font-mono text-accent font-bold tracking-widest uppercase mb-1">03 / CREATE</span>
            <span class="text-xs text-foreground-secondary">Tech Journals</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[10px] font-mono text-accent font-bold tracking-widest uppercase mb-1">04 / LEAD</span>
            <span class="text-xs text-foreground-secondary">Summits</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Asymmetric Visual collage of styled student active frames (5 Columns) -->
      <div class="lg:col-span-5 relative flex items-center justify-center w-full min-h-[380px] lg:min-h-[440px] reveal" style="transition-delay: 150ms;">
        <!-- Frame 1: Main Styled Collage Graphic -->
        <div class="absolute w-[80%] h-[260px] rounded-lg overflow-hidden bg-surface-secondary border border-border-strong/60 shadow-medium p-4 rotate-[-3deg] z-10 transition-transform hover:rotate-0 hover:scale-[1.02] duration-300">
          <div class="w-full h-full rounded-md bg-gradient-to-br from-accent/10 to-accent-blue/10 flex flex-col justify-between p-5 border border-accent/10 select-none">
            <div class="flex justify-between items-start">
              <span class="text-[9px] font-mono font-bold tracking-widest text-accent uppercase">CSEA // DEV_SQUAD</span>
              <span class="text-[9px] font-mono text-foreground-muted font-medium">SYS_INIT_VER_3.5</span>
            </div>
            <div class="font-mono text-[12px] text-foreground-secondary leading-normal">
              <span class="text-accent">&gt;_</span> npm install @csea/core<br/>
              <span class="text-foreground-muted">// Linking nodes...</span><br/>
              <span class="text-success">Connected: KITSW_AUDITORIUM</span>
            </div>
            <div>
              <h4 class="font-sans font-semibold text-[17px] leading-tight text-foreground mb-1">Innovation Lab Operations</h4>
              <p class="text-[12px] text-foreground-secondary">Students designing interface architectures and routing systems together.</p>
            </div>
          </div>
        </div>

        <!-- Frame 2: Back Accent graphic (Offset offset-x, offset-y) -->
        <div class="absolute w-[75%] h-[240px] rounded-lg bg-dark-canvas border border-dark-border shadow-strong p-4 rotate-[6deg] translate-y-8 translate-x-12 z-0 opacity-80 hover:scale-[1.02] transition-transform duration-300">
          <div class="w-full h-full flex flex-col justify-between font-mono text-[11px] text-dark-foreground-muted leading-relaxed select-none">
            <div class="flex justify-between border-b border-dark-border pb-2">
              <span class="text-accent font-bold">NODE_02 // WORKSHOP</span>
              <span>15 AUG '26</span>
            </div>
            <div class="flex-1 flex items-center justify-center py-4">
              <svg class="w-16 h-16 opacity-30 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="text-[10px] text-accent/80">
              STATUS: PREPARING STAGE_01
            </div>
          </div>
        </div>

        <!-- Frame 3: Small Overlay coordinate sticker -->
        <div class="absolute bottom-2 left-6 bg-surface border border-accent rounded-md px-3 py-1.5 shadow-soft z-20 rotate-[-12deg] font-mono text-[10px] text-foreground font-semibold flex items-center gap-1.5 animate-bounce">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span>
          <span>158 NEW MEMBERS REACHED</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. ABOUT / STATEMENT SECTION -->
  <section class="py-24 bg-surface-secondary border-y border-border">
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8">
      
      <!-- Top Statement Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start mb-20 reveal">
        
        <!-- Left: Statement (7 Columns) -->
        <div class="lg:col-span-7">
          <span class="text-[11px] font-mono tracking-[0.12em] text-accent font-bold uppercase mb-4 block">// Editorial Manifesto</span>
          <h2 class="text-display-lg text-foreground text-balance">
            Built by students. Backed by a department. Created for everyone.
          </h2>
        </div>
        
        <!-- Right: Supporting Details (5 Columns) -->
        <div class="lg:col-span-5 text-body text-foreground-secondary leading-relaxed pt-2">
          <p class="mb-4">
            CSEA connects classrooms with real-world development environments. We assemble student product squads to construct departmental systems, organize technical summits, and publish student architectures.
          </p>
          <p>
            We operate transparently to train students in industry standards of collaborative version control, modular system design, and database architectures.
          </p>
        </div>
      </div>

      <!-- Bottom: Large Typographic Grid (No cards, thin dividers) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 pt-12 border-t border-border-strong/60 reveal" style="transition-delay: 100ms;">
        <div class="flex flex-col pr-4 border-r border-border last:border-none">
          <span class="text-[64px] font-bold tracking-tight leading-none text-foreground font-sans">28+</span>
          <span class="text-[11px] font-mono tracking-[0.1em] text-foreground-muted uppercase mt-3">Years of Heritage</span>
        </div>
        <div class="flex flex-col pr-4 border-r border-border last:border-none">
          <span class="text-[64px] font-bold tracking-tight leading-none text-foreground font-sans">150+</span>
          <span class="text-[11px] font-mono tracking-[0.1em] text-foreground-muted uppercase mt-3">Events Conducted</span>
        </div>
        <div class="flex flex-col pr-4 border-r border-border last:border-none">
          <span class="text-[64px] font-bold tracking-tight leading-none text-foreground font-sans">800+</span>
          <span class="text-[11px] font-mono tracking-[0.1em] text-foreground-muted uppercase mt-3">Students Enrolled</span>
        </div>
        <div class="flex flex-col">
          <span class="text-[64px] font-bold tracking-tight leading-none text-foreground font-sans">20+</span>
          <span class="text-[11px] font-mono tracking-[0.1em] text-foreground-muted uppercase mt-3">Active Projects</span>
        </div>
      </div>

    </div>
  </section>

  <!-- 4. WHAT WE DO — INTERACTIVE SECTION -->
  <section class="py-24 bg-canvas overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8">
      
      <div class="mb-16 reveal">
        <span class="text-[11px] font-mono tracking-[0.1em] text-accent font-bold uppercase mb-2 block">// Core Programs</span>
        <h2 class="text-display-lg text-foreground">What We Do.</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        
        <!-- Left: Interactive Visual Display (6 Columns) -->
        <div class="lg:col-span-6 relative aspect-[4/3] rounded-lg overflow-hidden bg-surface-secondary border border-border shadow-soft p-3 reveal">
          <div id="interactive-display-bg" class="w-full h-full rounded-md bg-gradient-to-br from-accent/5 to-accent-blue/10 flex flex-col justify-between p-6 transition-all duration-300 select-none">
            <div class="flex justify-between items-start">
              <span id="display-label" class="text-[10px] font-mono text-accent font-bold tracking-widest">PROGRAM // TECHNICAL EVENTS</span>
              <span class="text-[10px] font-mono text-foreground-muted">CSEA KITSW</span>
            </div>
            
            <div class="flex-1 flex items-center justify-center py-6">
              <div id="display-graphic" class="text-foreground opacity-90 w-full max-w-[280px]">
                <!-- Dynamic SVG will render here -->
                <svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polygon points="50,15 90,85 10,85" />
                  <circle cx="50" cy="50" r="15" />
                </svg>
              </div>
            </div>

            <div>
              <p id="display-description" class="text-[14px] text-foreground-secondary leading-relaxed font-sans">
                Annual code summits, debug hackathons, and algorithm contests where students challenge each other.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Interactive Navigation Tabs List (6 Columns) -->
        <div class="lg:col-span-6 flex flex-col gap-2 reveal" style="transition-delay: 100ms;">
          
          <button class="interactive-tab text-left p-6 rounded-lg border border-border hover:border-border-strong bg-surface hover:bg-surface-secondary transition-all group" data-category="tech-events">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Technical Events</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">01 / CONTESTS</span>
            </div>
          </button>

          <button class="interactive-tab text-left p-6 rounded-lg border border-transparent bg-transparent hover:bg-surface-secondary transition-all group" data-category="workshops">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Workshops & Learning</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">02 / EDUCATION</span>
            </div>
          </button>

          <button class="interactive-tab text-left p-6 rounded-lg border border-transparent bg-transparent hover:bg-surface-secondary transition-all group" data-category="projects">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Projects & Innovation</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">03 / SQUADS</span>
            </div>
          </button>

          <button class="interactive-tab text-left p-6 rounded-lg border border-transparent bg-transparent hover:bg-surface-secondary transition-all group" data-category="community">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Community Collaboration</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">04 / NETWORK</span>
            </div>
          </button>

          <button class="interactive-tab text-left p-6 rounded-lg border border-transparent bg-transparent hover:bg-surface-secondary transition-all group" data-category="publications">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Publications</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">05 / JOURNAL</span>
            </div>
          </button>

          <button class="interactive-tab text-left p-6 rounded-lg border border-transparent bg-transparent hover:bg-surface-secondary transition-all group" data-category="leadership">
            <div class="flex items-center justify-between">
              <h3 class="text-[20px] font-semibold text-foreground group-hover:text-accent transition-colors leading-none">Student Leadership</h3>
              <span class="font-mono text-xs text-foreground-muted group-hover:text-accent">06 / BOARD</span>
            </div>
          </button>

        </div>

      </div>

    </div>
  </section>

  <!-- Script for Interactive Program Selector -->
  <script>
    const data = {
      "tech-events": {
        label: "PROGRAM // TECHNICAL EVENTS",
        desc: "Annual code summits, debug hackathons, and algorithm contests where students challenge each other.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <polygon points="50,15 90,85 10,85" stroke="var(--accent)" />
                <circle cx="50" cy="50" r="15" stroke="var(--accent)" />
              </svg>`
      },
      "workshops": {
        label: "PROGRAM // WORKSHOPS & TRAINING",
        desc: "Regular developer bootcamps covering Full Stack, Machine Learning, and cloud technologies led by alumni and core members.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="20" y="20" width="60" height="60" rx="4" stroke="var(--accent)" />
                <line x1="20" y1="50" x2="80" y2="50" stroke="var(--accent)" />
                <circle cx="50" cy="35" r="6" stroke="var(--accent)" />
              </svg>`
      },
      "projects": {
        label: "PROGRAM // PROJECTS & SQUADS",
        desc: "Structured development squads that build actual departmental applications, dashboard platforms, and local lab automations.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20,30 L50,15 L80,30 L50,45 Z" stroke="var(--accent)" />
                <path d="M20,60 L50,75 L80,60" stroke="var(--accent)" />
                <path d="M50,45 L50,75" stroke="var(--accent)" />
              </svg>`
      },
      "community": {
        label: "PROGRAM // COMMUNITY COLLABORATION",
        desc: "Social network and peer mentorship channels linking juniors with board seniors and academic faculty guides.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="30" cy="30" r="10" stroke="var(--accent)" />
                <circle cx="70" cy="30" r="10" stroke="var(--accent)" />
                <circle cx="50" cy="70" r="10" stroke="var(--accent)" />
                <line x1="38" y1="36" x2="44" y2="61" stroke="var(--accent)" />
                <line x1="62" y1="36" x2="56" y2="61" stroke="var(--accent)" />
                <line x1="40" y1="30" x2="60" y2="30" stroke="var(--accent)" />
              </svg>`
      },
      "publications": {
        label: "PROGRAM // JOURNAL & PUBLISHING",
        desc: "Writing design case studies, architecture summaries, and event dispatches on our editorial technical publication platform.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="25" y="15" width="50" height="70" rx="2" stroke="var(--accent)" />
                <line x1="35" y1="30" x2="65" y2="30" stroke="var(--accent)" />
                <line x1="35" y1="45" x2="65" y2="45" stroke="var(--accent)" />
                <line x1="35" y1="60" x2="55" y2="60" stroke="var(--accent)" />
              </svg>`
      },
      "leadership": {
        label: "PROGRAM // STUDENT LEADERSHIP",
        desc: "Developing organizational, communication, and event execution capabilities through core administrative committees.",
        svg: `<svg viewBox="0 0 100 100" class="w-24 h-24 mx-auto text-accent" fill="none" stroke="currentColor" stroke-width="1.5">
                <polygon points="50,15 63,40 91,44 70,64 75,92 50,79 25,92 30,64 9,44 37,40" stroke="var(--accent)" />
              </svg>`
      }
    };

    const tabs = document.querySelectorAll('.interactive-tab');
    const displayBg = document.getElementById('interactive-display-bg');
    const displayLabel = document.getElementById('display-label');
    const displayDesc = document.getElementById('display-description');
    const displayGraphic = document.getElementById('display-graphic');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Toggle selected state border and background styles
        tabs.forEach(t => {
          t.classList.remove('border-border', 'bg-surface');
          t.classList.add('border-transparent', 'bg-transparent');
        });
        tab.classList.add('border-border', 'bg-surface');
        tab.classList.remove('border-transparent', 'bg-transparent');

        const cat = tab.getAttribute('data-category');
        if (cat && data[cat]) {
          // Trigger animations
          if (displayBg) {
            displayBg.style.opacity = '0.5';
            setTimeout(() => {
              if (displayLabel) displayLabel.textContent = data[cat].label;
              if (displayDesc) displayDesc.textContent = data[cat].desc;
              if (displayGraphic) displayGraphic.innerHTML = data[cat].svg;
              displayBg.style.opacity = '1';
            }, 150);
          }
        }
      });
    });
  </script>

  <!-- 5. EVENTS TIMELINE SECTION -->
  <section class="py-24 bg-surface-secondary border-t border-border">
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal">
        <div>
          <span class="text-[11px] font-mono tracking-[0.1em] text-accent font-bold uppercase mb-2 block">// Roadmaps & summits</span>
          <h2 class="text-display-lg text-foreground">Summits & Events.</h2>
        </div>
        <a href="/events" class="text-[14px] font-semibold text-accent hover:underline no-underline mt-4 md:mt-0 inline-flex items-center gap-1">
          View all scheduled dispatches &rarr;
        </a>
      </div>

      <!-- Grid layout: Featured + Stacked -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Large Featured Event Card (7 Columns) -->
        <div class="lg:col-span-7 bg-surface border border-border rounded-lg p-6 lg:p-8 flex flex-col justify-between min-h-[420px] shadow-soft group hover:border-accent/40 transition-colors duration-300 reveal">
          <div>
            <div class="flex justify-between items-center text-[12px] text-foreground-muted mb-6 font-mono">
              <span>AUG 15, 2026 // 09:00 AM</span>
              <span class="badge badge-accent bg-accent-muted text-accent font-semibold">Featured Orientation</span>
            </div>
            
            <!-- Graphic inside event card -->
            <div class="w-full aspect-[21/9] rounded-md bg-canvas border border-border flex items-center justify-center font-mono text-[11px] text-foreground-muted mb-8 select-none p-4">
              <svg class="w-12 h-12 text-accent opacity-20 mr-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
              <div>
                <span class="text-foreground font-bold">EVENT_SPACE // MAIN_AUDITORIUM</span><br/>
                <span class="text-[10px]">COORDS: 17.9712 N, 79.5318 E</span>
              </div>
            </div>

            <h3 class="text-display-md text-foreground group-hover:text-accent transition-colors mb-4">
              CSEA Orientation 2026
            </h3>
            <p class="text-body-sm text-foreground-secondary leading-relaxed mb-8 max-w-[580px]">
              Meet the faculty advisors and student executive board to explore CSEA's roadmap for the upcoming academic year. Mandatory for all new CS students.
            </p>
          </div>
          <div class="pt-6 border-t border-border flex flex-wrap items-center justify-between gap-4 mt-auto">
            <span class="text-xs font-mono text-foreground-secondary">VENUE / AUDITORIUM CAMPUS</span>
            <a href="/events/orientation-26" class="btn btn-outline text-xs px-5 py-2.5">
              Registration Pass &rarr;
            </a>
          </div>
        </div>

        <!-- Stacked Secondary Events (5 Columns) -->
        <div class="lg:col-span-5 flex flex-col gap-6 reveal" style="transition-delay: 100ms;">
          
          <!-- Event item 2 -->
