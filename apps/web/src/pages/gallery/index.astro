---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gallery Archive & Moments | CSEA">
  
  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="0" y1="20" x2="100" y2="80" stroke="var(--accent)" stroke-width="0.3" />
      </svg>
    </div>
    
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">
      
      <!-- Header -->
      <div class="mb-16 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // CAPTURED OPERATIONS
        </div>
        <h1 class="text-display-lg mb-4 text-foreground">Gallery.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          A visual log of student building sprints, orientation meets, panels, and project launches.
        </p>
      </div>

      <!-- Categories filters -->
      <div class="flex items-center gap-3 border-b border-border pb-6 mb-16 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11px] font-mono text-foreground-muted tracking-wider uppercase mr-4 whitespace-nowrap">// CHRONO_BLOCK</span>
        <a href="#" class="text-[13px] font-semibold text-white bg-accent px-4 py-2 rounded-md whitespace-nowrap shadow-soft no-underline">Academic Year 2026</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Year 2025</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Year 2024</a>
      </div>

      <!-- Asymmetric Mosaic Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal" style="transition-delay: 100ms;">
        
        <!-- Album card 1 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent/40 rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border p-4 flex items-center justify-center select-none font-mono text-[10px] text-foreground-secondary">
            <div class="w-full h-full rounded border border-dashed border-border-strong/40 flex flex-col justify-between p-4 group-hover:scale-[1.03] transition-transform duration-500">
              <div class="flex justify-between items-start">
                <span>COM_ALB // HACKATHON_26</span>
                <span>STAGE_02</span>
              </div>
              <div class="flex justify-center">
                <svg class="w-12 h-12 text-accent opacity-20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              </div>
              <span>COORDS // INNOVATION_LABS</span>
            </div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Autumn '26</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// CODING SUMMIT</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">Autumn Hackathon 2026</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Sep 10, 2026 &middot; <span class="font-mono text-accent">342 Photos</span></span>
              <span class="font-medium text-foreground group-hover:text-accent transition-colors">View Photos &rarr;</span>
            </div>
          </div>
        </a>

        <!-- Album card 2 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent/40 rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border p-4 flex items-center justify-center select-none font-mono text-[10px] text-foreground-secondary">
            <div class="w-full h-full rounded border border-dashed border-border-strong/40 flex flex-col justify-between p-4 group-hover:scale-[1.03] transition-transform duration-500">
              <div class="flex justify-between items-start">
                <span>COM_ALB // ORIENTATION_26</span>
                <span>STAGE_01</span>
              </div>
              <div class="flex justify-center">
                <svg class="w-12 h-12 text-accent opacity-20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              </div>
              <span>COORDS // MAIN_AUDITORIUM</span>
            </div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Ceremonial</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// WELCOME GATHERINGS</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">CSEA Orientation 2026</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Aug 15, 2026 &middot; <span class="font-mono text-accent">128 Photos</span></span>
              <span class="font-medium text-foreground group-hover:text-accent transition-colors">View Photos &rarr;</span>
            </div>
          </div>
        </a>

        <!-- Album card 3 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent/40 rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border p-4 flex items-center justify-center select-none font-mono text-[10px] text-foreground-secondary">
            <div class="w-full h-full rounded border border-dashed border-border-strong/40 flex flex-col justify-between p-4 group-hover:scale-[1.03] transition-transform duration-500">
              <div class="flex justify-between items-start">
                <span>COM_ALB // TECH_TALK</span>
                <span>SEMINAR</span>
              </div>
              <div class="flex justify-center">
                <svg class="w-12 h-12 text-accent opacity-20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              </div>
              <span>COORDS // CAMPUS_BLOCK_2</span>
            </div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Academic</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// SYSTEMS SEMINAR</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">Tech Talk: Systems</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Aug 22, 2026 &middot; <span class="font-mono text-accent">45 Photos</span></span>
              <span class="font-medium text-foreground group-hover:text-accent transition-colors">View Photos &rarr;</span>
            </div>
          </div>
        </a>

      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
