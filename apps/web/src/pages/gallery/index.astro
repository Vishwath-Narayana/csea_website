---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gallery Archive & Moments | CSEA">
  
  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 glow-ambient opacity-20 pointer-events-none"></div>
    
    <div class="max-w-content mx-auto px-4 lg:px-8 relative z-10">
      
      <!-- Header -->
      <div class="mb-16 reveal">
        <div class="text-[11px] font-mono text-accent font-semibold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span> CAPTURED OPERATIONS
        </div>
        <h1 class="text-display-lg mb-4 text-foreground">Archive.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          A visual log of student building sprints, orientation meets, panels, and project launches.
        </p>
      </div>

      <!-- Categories filters -->
      <div class="flex gap-3 border-b border-border pb-6 mb-16 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11.5px] font-mono text-foreground-subtle tracking-wider uppercase mr-2">// CHRONO_BLOCK</span>
        <a href="#" class="text-[13px] font-semibold text-white bg-accent px-4 py-1.5 rounded-lg whitespace-nowrap shadow-soft no-underline">Academic Year 2026</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface/50 border border-border px-4 py-1.5 rounded-lg whitespace-nowrap transition-colors no-underline">Year 2025</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface/50 border border-border px-4 py-1.5 rounded-lg whitespace-nowrap transition-colors no-underline">Year 2024</a>
      </div>

      <!-- Asymmetric Mosaic Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal" style="transition-delay: 100ms;">
        
        <!-- Album card 1 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent rounded-2xl overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border">
            <div class="img-placeholder w-full h-full transition-transform duration-700 group-hover:scale-103">Hackathon Gallery Covers</div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Autumn '26</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// CODING SUMMIT</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">Autumn Hackathon 2026</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Sep 10, 2026</span>
              <span class="font-mono text-accent">342 Photos</span>
            </div>
          </div>
        </a>

        <!-- Album card 2 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent rounded-2xl overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border">
            <div class="img-placeholder w-full h-full transition-transform duration-700 group-hover:scale-103">Orientation Gallery Covers</div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Ceremonial</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// WELCOME GATHERINGS</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">CSEA Orientation 2026</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Aug 15, 2026</span>
              <span class="font-mono text-accent">128 Photos</span>
            </div>
          </div>
        </a>

        <!-- Album card 3 -->
        <a href="/gallery/hackathon" class="group no-underline bg-surface border border-border hover:border-accent rounded-2xl overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300">
          <div class="w-full aspect-[4/3] relative bg-surface-secondary border-b border-border">
            <div class="img-placeholder w-full h-full transition-transform duration-700 group-hover:scale-103">Seminars Gallery Covers</div>
            <div class="absolute top-4 left-4 badge badge-accent bg-surface/90 backdrop-blur-md">Academic</div>
          </div>
          <div class="p-6">
            <div class="text-[10px] font-mono text-foreground-muted tracking-wider uppercase mb-1.5">// SYSTEMS SEMINAR</div>
            <h2 class="text-h2 font-semibold text-foreground group-hover:text-accent transition-colors leading-tight mb-2">Tech Talk: Systems</h2>
            <div class="flex justify-between items-center text-[12.5px] text-foreground-secondary pt-4 border-t border-border mt-4">
              <span>Aug 22, 2026</span>
              <span class="font-mono text-accent">45 Photos</span>
            </div>
          </div>
        </a>

      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
