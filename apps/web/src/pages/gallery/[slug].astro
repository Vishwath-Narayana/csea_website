---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'hackathon' } },
  ];
}
---

<Layout title="Autumn Hackathon 2026 Photos | Gallery | CSEA">
  
  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="0" y1="50" x2="100" y2="50" stroke="var(--accent)" stroke-width="0.3" stroke-dasharray="1 1" />
      </svg>
    </div>
    
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">
      
      <!-- Header -->
      <header class="mb-16 text-center reveal">
        <div class="inline-flex items-center justify-center gap-3.5 mb-4 text-[12px] font-mono text-foreground-muted uppercase">
          <a href="/gallery" class="hover:text-accent transition-colors no-underline">Gallery</a>
          <span>/</span>
          <span class="text-accent font-semibold">2026-2027</span>
        </div>
        <h1 class="text-display-md mb-4 text-balance text-foreground leading-tight">Autumn Hackathon 2026</h1>
        <p class="text-body text-foreground-secondary max-w-2xl mx-auto leading-relaxed">
          A visual report capturing the 24-hour coding sprint inside the Innovation Lab.
        </p>
        <div class="text-[12px] text-foreground-muted font-mono mt-6 flex items-center justify-center gap-4">
          <span>DATE // SEP 10, 2026</span>
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          <span>ENTRIES // 342 IMAGES</span>
        </div>
      </header>

      <!-- Advanced Mosaic Grid Layout -->
      <div class="reveal" style="transition-delay: 100ms;">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 auto-rows-[150px] sm:auto-rows-[250px] lg:auto-rows-[300px]">
          
          <!-- Large Feature photo -->
          <div class="col-span-2 row-span-2 border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-4 font-mono text-[9px] text-foreground-secondary bg-gradient-to-tr from-accent/10 to-accent-blue/5 border border-accent/5">
              <span class="text-[8px] uppercase">// Coords: STAGE_02_INNOVATION</span>
              <span class="text-center font-bold text-xs uppercase text-foreground leading-snug">Team Working Sprint // Hero Media</span>
              <span class="text-right text-[8px] uppercase">CAM_01_LENS</span>
            </div>
          </div>

          <!-- Standard Photo -->
          <div class="border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-br from-accent/5 to-accent-blue/10 border border-accent/5">
              <span>// DEPT_STAGE</span>
              <span class="text-center font-semibold text-[11px] text-foreground uppercase">Hardware setup</span>
              <span>CAM_02</span>
            </div>
          </div>

          <!-- Standard Photo -->
          <div class="border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-br from-accent/5 to-accent-blue/10 border border-accent/5">
              <span>// LABS_BOARDS</span>
              <span class="text-center font-semibold text-[11px] text-foreground uppercase">Whiteboard drafts</span>
              <span>CAM_03</span>
            </div>
          </div>

          <!-- Wide Photo -->
          <div class="col-span-2 border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-tr from-accent/10 to-accent-blue/5 border border-accent/5">
              <span>// COORDS: LABS_BLOCK_2</span>
              <span class="text-center font-semibold text-[12px] text-foreground uppercase">Mentoring evaluations</span>
              <span>CAM_04</span>
            </div>
          </div>

          <!-- Tall Photo -->
          <div class="row-span-2 border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-br from-accent/5 to-accent-blue/10 border border-accent/5">
              <span>// MONITOR_SCREEN</span>
              <span class="text-center font-semibold text-[11px] text-foreground uppercase leading-tight py-12">Code review screen</span>
              <span>CAM_05</span>
            </div>
          </div>

          <!-- Standard Photo -->
          <div class="border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-br from-accent/5 to-accent-blue/10 border border-accent/5">
              <span>// SNACK_BREAK</span>
              <span class="text-center font-semibold text-[11px] text-foreground uppercase">Snack bar</span>
              <span>CAM_06</span>
            </div>
          </div>

          <!-- Standard Photo -->
          <div class="border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-br from-accent/5 to-accent-blue/10 border border-accent/5">
              <span>// AWARD_STAGE</span>
              <span class="text-center font-semibold text-[11px] text-foreground uppercase">Closing ceremony</span>
              <span>CAM_07</span>
            </div>
          </div>

          <!-- Wide Photo -->
          <div class="col-span-2 border border-border rounded-lg overflow-hidden bg-surface p-2 shadow-soft hover:shadow-medium group cursor-pointer transition-all duration-300">
            <div class="img-placeholder w-full h-full rounded transition-transform duration-700 group-hover:scale-[1.01] flex flex-col justify-between p-3 font-mono text-[8px] text-foreground-secondary bg-gradient-to-tr from-accent/10 to-accent-blue/5 border border-accent/5">
              <span>// COORDS: MAIN_HALL</span>
              <span class="text-center font-semibold text-[12px] text-foreground uppercase">Final presentations grid</span>
              <span>CAM_08</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

</Layout>
