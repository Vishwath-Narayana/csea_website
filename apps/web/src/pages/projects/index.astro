---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Systems & Open Source Projects | CSEA">
  
  <div class="dark-env bg-canvas bg-grid-blueprint-dark min-h-screen text-foreground pt-28 pb-32 relative">
    <div class="absolute inset-0 pointer-events-none select-none opacity-20">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="0" y1="40" x2="100" y2="60" stroke="var(--accent)" stroke-width="0.3" stroke-dasharray="2 2" />
      </svg>
    </div>
    
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">
      
      <!-- Header -->
      <div class="mb-20 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // SYSTEM LABS & MONOREPOS
        </div>
        <h1 class="text-display-lg mb-4 text-foreground">Projects.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Build systems that solve real problems. Join an engineering squad, write production-grade code, and deploy campus services.
        </p>
      </div>

      <!-- Filters -->
      <div class="flex items-center gap-3 border-b border-dark-border pb-6 mb-20 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11px] font-mono text-dark-foreground-muted tracking-wider uppercase mr-4 whitespace-nowrap">// REGISTRY_STATUS</span>
        <a href="#" class="text-[13px] font-semibold text-white bg-accent px-4 py-2 rounded-md whitespace-nowrap shadow-soft no-underline">Open Positions</a>
        <a href="#" class="text-[13px] font-medium text-dark-foreground-muted hover:text-dark-foreground bg-dark-surface/50 border border-dark-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Active Builds</a>
        <a href="#" class="text-[13px] font-medium text-dark-foreground-muted hover:text-dark-foreground bg-dark-surface/50 border border-dark-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Shipped & Legacy</a>
      </div>

      <!-- Projects Grid Layout -->
      <div class="grid grid-cols-1 gap-8 reveal" style="transition-delay: 100ms;">
        
        <!-- Project 1 (Recruiting) -->
        <a href="/projects/platform" class="group no-underline bg-dark-surface border border-dark-border hover:border-accent/40 hover:-translate-y-[2px] hover:shadow-medium rounded-lg p-6 lg:p-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8 relative overflow-hidden transition-all duration-300 shadow-soft">
          <!-- Spotlight hover effect -->
          <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

          <div class="flex-1 z-10">
            <div class="flex flex-wrap items-center gap-3.5 mb-4 text-[11px] font-mono text-dark-foreground-muted uppercase">
              <span class="badge badge-accent shadow-sm">Recruiting</span>
              <span class="flex items-center gap-1.5">// Web Systems</span>
            </div>
            
            <h2 class="text-display-md text-foreground mb-4 group-hover:text-accent transition-colors leading-tight">
              CSEA Digital Platform
            </h2>
            
            <p class="text-body-sm text-foreground-secondary max-w-3xl mb-8 leading-relaxed">
              Building the core digital backbone for the association. Features a public Astro web engine, custom administrative console, Fastify REST APIs, and PostgreSQL database migrations.
            </p>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 pt-6 border-t border-dark-border mt-4">
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">TECH STACK</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">Astro, React, Fastify, PG</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">SQUAD SIZE</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">6 Engineers</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">OPEN ROLES</div>
                <div class="text-[13.5px] font-medium text-accent font-bold">3 Frontend, 1 Backend</div>
              </div>
            </div>
          </div>
          
          <div class="flex-shrink-0 z-10 w-full lg:w-auto mt-6 lg:mt-0">
            <span class="btn bg-dark-surface-2 text-dark-foreground border border-dark-border hover:bg-dark-surface-3 w-full lg:w-auto font-semibold px-8 py-3.5 rounded-lg shadow-medium text-center block">
              View Roles &rarr;
            </span>
          </div>
        </a>

        <!-- Project 2 (Active Building) -->
        <a href="/projects/attendance-system" class="group no-underline bg-dark-surface border border-dark-border hover:border-accent/40 hover:-translate-y-[2px] hover:shadow-medium rounded-lg p-6 lg:p-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8 relative overflow-hidden transition-all duration-300 shadow-soft">
          <div class="flex-1 z-10">
            <div class="flex flex-wrap items-center gap-3.5 mb-4 text-[11px] font-mono text-dark-foreground-muted uppercase">
              <span class="badge badge-success shadow-sm">Active Building</span>
              <span class="flex items-center gap-1.5">// Embedded Gateways</span>
            </div>
            
            <h2 class="text-display-md text-foreground mb-4 group-hover:text-accent transition-colors leading-tight">
              Automated Attendance System
            </h2>
            
            <p class="text-body-sm text-foreground-secondary max-w-3xl mb-8 leading-relaxed">
              An RFID and biometric integrated attendance logging system for department labs. Direct interface to localized SQLite registers and campus synchronization hooks.
            </p>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 pt-6 border-t border-dark-border mt-4">
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">TECH STACK</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">Python, Raspberry Pi, Go</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">SQUAD SIZE</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">4 Hardware Devs</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">DEV_STAGE</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">Beta testing gateway</div>
              </div>
            </div>
          </div>
        </a>

        <!-- Project 3 (Shipped) -->
        <a href="/projects/alumni-portal" class="group no-underline bg-dark-surface border border-dark-border rounded-lg p-6 lg:p-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8 relative overflow-hidden transition-all duration-300 opacity-60 hover:opacity-100 hover:border-dark-border-strong hover:-translate-y-[2px] hover:shadow-medium shadow-soft">
          <div class="flex-1 z-10">
            <div class="flex flex-wrap items-center gap-3.5 mb-4 text-[11px] font-mono text-dark-foreground-muted uppercase">
              <span class="badge badge-muted shadow-sm">Shipped & Legacy</span>
              <span class="flex items-center gap-1.5">// Networking</span>
            </div>
            
            <h2 class="text-display-md text-foreground mb-4 leading-tight">
              Alumni Network Portal
            </h2>
            
            <p class="text-body-sm text-foreground-secondary max-w-3xl mb-8 leading-relaxed">
              A directory and networking platform connecting current students with KITSW CSE alumni across the globe. Built, verified, and shipped to core alumni server.
            </p>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 pt-6 border-t border-dark-border mt-4">
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">SHIPPED DATE</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">May 2025</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase text-dark-foreground-muted mb-1.5">LIFETIME USERS</div>
                <div class="text-[13.5px] font-medium text-dark-foreground">800+ Members</div>
              </div>
            </div>
          </div>
        </a>

      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
