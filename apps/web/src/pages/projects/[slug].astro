---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';

let project = null;
try {
  const res = await fetch(`${API_URL}/api/v1/projects/${slug}`);
  if (res.ok) {
    const data = await res.json();
    project = data.data;
  }
} catch (e) {
  console.error("Failed to fetch project details", e);
}

if (!project) {
  return Astro.redirect('/404');
}

const getStatusBadgeClass = (status: string) => {
  switch(status) {
    case 'RECRUITING': return 'badge-accent shadow-sm';
    case 'ACTIVE': return 'badge-success shadow-sm';
    case 'COMPLETED': return 'badge-muted shadow-sm';
    default: return 'badge-muted shadow-sm';
  }
};

const getStatusLabel = (status: string) => {
  switch(status) {
    case 'RECRUITING': return 'Recruiting';
    case 'ACTIVE': return 'Active Building';
    case 'COMPLETED': return 'Shipped & Legacy';
    default: return status;
  }
};
---

<Layout title={`${project.title} | CSEA`}>
  
  <div class="dark-env bg-canvas bg-grid-blueprint-dark min-h-screen text-foreground pt-28 pb-32 relative">
    <div class="absolute inset-0 pointer-events-none select-none opacity-20">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0,30 Q50,70 100,30" stroke="var(--accent)" stroke-width="0.3" fill="none" stroke-dasharray="1 1" />
      </svg>
    </div>
    
    <!-- Project Header -->
    <header class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 mb-20 relative z-10 reveal">
      <div class="flex items-center gap-3.5 mb-6 text-[12px] font-mono text-dark-foreground-muted uppercase">
        <a href="/projects" class="hover:text-accent transition-colors no-underline">Projects</a>
        <span>/</span>
        <span class={`font-semibold ${project.status === 'RECRUITING' ? 'text-accent' : 'text-dark-foreground-muted'}`}>
          {getStatusLabel(project.status)}
        </span>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <h1 class="text-display-lg mb-6 leading-tight text-foreground">{project.title}</h1>
          <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
            {project.shortDescription || 'No description provided.'}
          </p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          {project.applicationUrl && (
            <a href={project.applicationUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary bg-accent hover:bg-accent-hover text-white px-8 py-3.5 rounded-lg font-semibold w-full sm:w-auto shadow-medium no-underline block text-center">
              Apply to Join Squad &darr;
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- Project Data Grid Specs -->
    <div class="border-y border-dark-border bg-dark-surface/35 backdrop-blur-sm relative z-10 reveal" style="transition-delay: 50ms;">
      <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 py-8 gap-8">
          <div>
            <div class="text-[10px] font-mono text-dark-foreground-muted tracking-wider uppercase mb-1.5">TIMELINE</div>
            <div class="text-[14px] font-bold text-foreground">{project.timeline || 'TBA'}</div>
          </div>
          <div>
            <div class="text-[10px] font-mono text-dark-foreground-muted tracking-wider uppercase mb-1.5">TECH ARCHITECTURE</div>
            <div class="text-[14px] font-bold text-foreground">{project.techStack?.join(', ') || 'N/A'}</div>
          </div>
          <div>
            <div class="text-[10px] font-mono text-dark-foreground-muted tracking-wider uppercase mb-1.5">ENGINEERING LEAD</div>
            <div class="text-[14px] font-bold text-foreground flex items-center gap-2">
              <span class="w-6 h-6 rounded bg-accent/10 border border-accent/30 flex items-center justify-center text-[9px] font-bold text-accent">L</span>
              {project.projectLead || 'Core Committee'}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Editorial Layout details -->
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 mt-20 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Scope & Mission details -->
      <div class="lg:col-span-7 text-body text-foreground-secondary leading-relaxed flex flex-col gap-8 reveal" style="transition-delay: 100ms;">
        <div>
          <h2 class="text-display-md text-foreground mb-4">Project Details</h2>
          <div class="prose prose-invert max-w-none">
            {project.fullDescription ? project.fullDescription.split('\n').map((p: string) => (
              <p class="mb-4">{p}</p>
            )) : <p>No detailed description available.</p>}
          </div>
        </div>

        {project.techStack && project.techStack.length > 0 && (
          <div class="border-t border-dark-border pt-6">
            <h3 class="text-h3 text-foreground mb-4">Tech Stack</h3>
            <div class="flex flex-wrap gap-2.5">
              {project.techStack.map((tech: string) => (
                <span class="px-3.5 py-2 rounded-md border border-dark-border bg-dark-surface text-[12.5px] font-medium text-dark-foreground">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right Column: Sidebar Position Details & Applications -->
      <div id="apply" class="lg:col-span-5 reveal" style="transition-delay: 150ms;">
        <div class="bg-dark-surface border border-dark-border rounded-lg p-6 lg:p-8 sticky top-24 shadow-medium flex flex-col gap-8">
          <div>
            <h3 class="text-h3 text-foreground leading-none mb-2">Links & Resources</h3>
          </div>

          <div class="flex flex-col gap-6 divide-y divide-dark-border">
            
            {project.applicationUrl && (
              <div class="pt-6 first:pt-0">
                <div class="flex justify-between items-center mb-2">
                  <h4 class="font-bold text-foreground text-[15px]">Join the Team</h4>
                </div>
                <a href={project.applicationUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline border-dark-border hover:bg-dark-surface-2 w-full text-center text-[12.5px] py-2.5 block no-underline text-dark-foreground">
                  Apply via External Link ↗
                </a>
              </div>
            )}
            
            {project.repositoryUrl && (
              <div class="pt-6 first:pt-0">
                <div class="flex justify-between items-center mb-2">
                  <h4 class="font-bold text-foreground text-[15px]">Repository</h4>
                </div>
                <a href={project.repositoryUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline border-dark-border hover:bg-dark-surface-2 w-full text-center text-[12.5px] py-2.5 block no-underline text-dark-foreground">
                  View Source Code ↗
                </a>
              </div>
            )}

            {project.demoUrl && (
              <div class="pt-6 first:pt-0">
                <div class="flex justify-between items-center mb-2">
                  <h4 class="font-bold text-foreground text-[15px]">Live Demo</h4>
                </div>
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline border-dark-border hover:bg-dark-surface-2 w-full text-center text-[12.5px] py-2.5 block no-underline text-dark-foreground">
                  View Demo ↗
                </a>
              </div>
            )}
          </div>
        </div>
      </div>

    </div>
  </div>

</Layout>
