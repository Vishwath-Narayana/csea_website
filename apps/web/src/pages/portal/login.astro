---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Student Login | CSEA Portal" darkFooter={false}>
  
  <div class="min-h-[calc(100vh-64px)] bg-canvas flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden">
    <!-- Network graphic backdrop (Subtle background paths) -->
    <div class="absolute inset-0 pointer-events-none select-none opacity-5 z-0">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="10" y1="10" x2="90" y2="90" stroke="var(--accent)" stroke-width="0.3" />
      </svg>
    </div>

    <div class="sm:mx-auto sm:w-full sm:max-w-md reveal relative z-10">
      <div class="flex justify-center mb-6">
        <a href="/" class="flex flex-col items-center group no-underline text-foreground">
          <span class="font-display font-semibold text-[24px] tracking-tight group-hover:text-accent transition-colors">CSEA</span>
          <span class="text-[11px] font-mono text-accent font-bold tracking-[0.1em] uppercase mt-1">// Student Portal</span>
        </a>
      </div>
      <h2 class="text-center text-display-md text-foreground mb-3">
        Sign in to your account
      </h2>
      <p class="text-center text-[15px] text-foreground-secondary max-w-sm mx-auto mb-1">
        One account for CSEA events, projects and opportunities.
      </p>
      <p class="text-center text-[13px] text-foreground-muted font-mono mt-3 bg-surface border border-border inline-block px-3 py-1 rounded-md mx-auto relative left-1/2 -translate-x-1/2">
        // Use your KITSW institutional email.
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md reveal relative z-10" style="transition-delay: 50ms;">
      <div class="bg-surface py-8 px-4 border border-border sm:rounded-lg sm:px-10 shadow-medium">
        
        <form class="space-y-6" action="/portal/dashboard" method="GET">
          <div>
            <label for="email" class="block text-[13px] font-medium text-foreground mb-1.5">
              Institutional Email
            </label>
            <div class="mt-1">
              <input id="email" name="email" type="email" autocomplete="email" required class="w-full bg-surface border border-border rounded-md px-3.5 py-2.5 text-[14px] text-foreground focus:outline-none focus:ring-4 focus:ring-accent/15 focus:border-accent transition-all shadow-sm" placeholder="b26cs000@kitsw.ac.in">
            </div>
          </div>

          <div>
            <label for="password" class="block text-[13px] font-medium text-foreground mb-1.5">
              Password
            </label>
            <div class="mt-1">
              <input id="password" name="password" type="password" autocomplete="current-password" required class="w-full bg-surface border border-border rounded-md px-3.5 py-2.5 text-[14px] text-foreground focus:outline-none focus:ring-4 focus:ring-accent/15 focus:border-accent transition-all shadow-sm">
            </div>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 text-accent focus:ring-accent border-border-strong rounded accent-accent">
              <label for="remember-me" class="ml-2 block text-[13px] text-foreground-secondary">
                Remember me
              </label>
            </div>

            <div class="text-[13px]">
              <a href="#" class="font-medium text-accent hover:underline">
                Forgot your password?
              </a>
            </div>
          </div>

          <div>
            <button type="submit" class="w-full flex justify-center btn btn-primary py-3.5 font-semibold text-[14px]">
              Sign in
            </button>
          </div>
        </form>

        <div class="mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-border"></div>
            </div>
            <div class="relative flex justify-center text-[12px] font-mono">
              <span class="px-2 bg-surface text-foreground-muted uppercase">
                // Admin access
              </span>
            </div>
          </div>

          <div class="mt-6">
            <a href="http://localhost:5173" class="w-full flex justify-center btn btn-outline py-2.5 text-[13px] rounded-lg">
              Go to CSEA Control
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

</Layout>
