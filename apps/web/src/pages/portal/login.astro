---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Student Login | CSEA Portal" darkFooter={false}>
  
  <div class="min-h-screen bg-canvas flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md reveal">
      <div class="flex justify-center mb-6">
        <a href="/" class="flex flex-col items-center group no-underline text-foreground">
          <span class="font-display font-semibold text-[24px] tracking-tight group-hover:text-accent transition-colors">CSEA</span>
          <span class="text-[11px] font-medium tracking-[0.04em] text-foreground-muted uppercase">Student Portal</span>
        </a>
      </div>
      <h2 class="text-center text-display-sm text-foreground">
        Sign in to your account
      </h2>
      <p class="mt-2 text-center text-[14px] text-foreground-secondary">
        Use your KITSW institutional email.
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md reveal" style="transition-delay: 50ms;">
      <div class="bg-surface py-8 px-4 shadow-soft border border-border sm:rounded-xl sm:px-10">
        
        <form class="space-y-6" action="/portal/dashboard" method="GET">
          <div>
            <label for="email" class="block text-[13px] font-medium text-foreground mb-1">
              Institutional Email
            </label>
            <div class="mt-1">
              <input id="email" name="email" type="email" autocomplete="email" required class="w-full bg-canvas border border-border-strong rounded-md px-3 py-2 text-[14px] text-foreground focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-shadow shadow-sm" placeholder="b26cs000@kitsw.ac.in">
            </div>
          </div>

          <div>
            <label for="password" class="block text-[13px] font-medium text-foreground mb-1">
              Password
            </label>
            <div class="mt-1">
              <input id="password" name="password" type="password" autocomplete="current-password" required class="w-full bg-canvas border border-border-strong rounded-md px-3 py-2 text-[14px] text-foreground focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent transition-shadow shadow-sm">
            </div>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 text-accent focus:ring-accent border-border-strong rounded accent-accent">
              <label for="remember-me" class="ml-2 block text-[13px] text-foreground-secondary">
                Remember me
              </label>
            </div>

            <div class="text-[13px]">
              <a href="#" class="font-medium text-accent hover:text-accent-hover">
                Forgot your password?
              </a>
            </div>
          </div>

          <div>
            <button type="submit" class="w-full flex justify-center btn btn-primary py-2.5">
              Sign in
            </button>
          </div>
        </form>

        <div class="mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-border"></div>
            </div>
            <div class="relative flex justify-center text-[13px]">
              <span class="px-2 bg-surface text-foreground-muted">
                Admin access
              </span>
            </div>
          </div>

          <div class="mt-6">
            <a href="http://localhost:5173" class="w-full flex justify-center btn btn-outline py-2 text-[13px]">
              Go to CSEA Control
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

</Layout>
