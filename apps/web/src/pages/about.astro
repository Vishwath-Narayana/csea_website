---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About the Association | CSEA">
  
  <!-- Page Header -->
  <section class="pt-28 pb-20 border-b border-border bg-canvas bg-grid-blueprint relative overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none select-none opacity-20">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0,50 Q50,70 100,50" stroke="var(--accent)" stroke-width="0.5" fill="none" />
      </svg>
    </div>
    
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // ASSOCIATION PROFILE
        </div>
        <h1 class="text-display-lg text-balance mb-6">
          Building the next generation of engineers.
        </h1>
        <p class="text-body-lg text-foreground-secondary mb-0 max-w-xl">
          The Computer Science & Engineering Association is the official student body of the CSE department at KITSW. We bridge the gap between academic theory and industry engineering.
        </p>
      </div>
      <div class="lg:col-span-5 reveal" style="transition-delay: 100ms;">
        <div class="aspect-[4/3] w-full bg-surface border border-border rounded-lg overflow-hidden shadow-medium p-3">
          <!-- Styled abstract illustration for association -->
          <div class="w-full h-full rounded bg-gradient-to-tr from-accent/15 to-accent-blue/15 flex flex-col justify-between p-6 select-none font-mono text-[10px] text-foreground-secondary">
            <div class="flex justify-between items-start">
              <span>SYS_UNIT // CSEA_COMMUNITY</span>
              <span>VER // 2026.1</span>
            </div>
            <div class="flex justify-center">
              <svg class="w-16 h-16 text-accent opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div class="text-right text-[9px] text-accent/80 font-bold">
              ESTD. 1998 // CSE KITSW
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Editorial layout: Core operations -->
  <section class="py-24 bg-surface-secondary">
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Key Principles -->
      <div class="lg:col-span-7 reveal text-body text-foreground-secondary leading-relaxed flex flex-col gap-6">
        <h2 class="text-display-md text-foreground mb-4">Our Philosophy</h2>
        <p>
          CSEA operates as a technology incubator within the college. We do not just host seminars; we assemble teams to build internal software, we organize hackathons to test engineering endurance, and we maintain an active technical journal.
        </p>
        <p class="mb-6">
          Our core philosophy is <strong>"Structured Energy"</strong> — taking the raw enthusiasm of CS students and channeling it into precise, production-level outputs. We treat student projects with the same rigor as industry development pipelines.
        </p>

        <div class="border-t border-border pt-6">
          <h3 class="text-h3 text-foreground mb-3">Technical Publishing</h3>
          <p class="text-body-sm text-foreground-secondary leading-relaxed">
            Through the CSEA Journal, we document architectures, system decisions, and lessons learned by our student body. Writing is thinking, and clear documentation is a core engineering requirement.
          </p>
        </div>

        <div class="border-t border-border pt-6">
          <h3 class="text-h3 text-foreground mb-3">Systems Engineering</h3>
          <p class="text-body-sm text-foreground-secondary leading-relaxed">
            We maintain CSEA's digital ecosystem, build automated lab tracking gateways, and ship open source utilities to assist the department. If a problem exists on campus, we build software to solve it.
          </p>
        </div>
      </div>

      <!-- Right Column: Sidebar structural hierarchy -->
      <div class="lg:col-span-5 reveal flex flex-col gap-8" style="transition-delay: 100ms;">
        <div class="bg-surface border border-border rounded-lg p-6 lg:p-8">
          <div class="text-[11px] font-mono text-accent font-bold tracking-wider uppercase mb-6">// ORGANIZATION HIERARCHY</div>
          
          <div class="flex flex-col gap-6 border-l-2 border-accent/25 pl-5">
            <div>
              <h4 class="font-semibold text-foreground text-[16px] leading-tight">Core Committee</h4>
              <p class="text-[13.5px] text-foreground-secondary mt-1.5">Final year students responsible for high-level strategy, system administration, and technical direction.</p>
            </div>
            <div>
              <h4 class="font-semibold text-foreground text-[16px] leading-tight">Joint Executives</h4>
              <p class="text-[13.5px] text-foreground-secondary mt-1.5">Third year students managing operations, squad projects delivery, and event logistics.</p>
            </div>
            <div>
              <h4 class="font-semibold text-foreground text-[16px] leading-tight">Executives</h4>
              <p class="text-[13.5px] text-foreground-secondary mt-1.5">Second year students assisting in operational execution and hands-on technical building.</p>
            </div>
          </div>
        </div>

        <!-- Callout block to Team page -->
        <div class="border border-dashed border-border-strong/60 rounded-lg p-6 lg:p-8 text-center bg-canvas">
          <h4 class="font-semibold text-foreground text-[16px] mb-2.5">Meet the people behind the platform</h4>
          <p class="text-[13.5px] text-foreground-secondary mb-6 leading-relaxed">
            See the full roster of core members, joint executives, and faculty advisors directing CSEA operations.
          </p>
          <a href="/team" class="btn btn-outline text-center text-[13.5px] w-full block">
            Meet the Core Team &rarr;
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>
