---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About the Association | CSEA">
  
  <!-- Page Header -->
  <section class="pt-28 pb-20 border-b border-border bg-canvas bg-grid-blueprint relative">
    <div class="absolute inset-0 glow-ambient opacity-20 pointer-events-none"></div>
    
    <div class="max-w-content mx-auto px-4 lg:px-8 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7 reveal">
        <div class="text-[11px] font-mono text-accent font-semibold tracking-widest uppercase mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span> ASSOCIATION PROFILE
        </div>
        <h1 class="text-display-lg text-balance mb-6">
          Building the next generation of engineers.
        </h1>
        <p class="text-body-lg text-foreground-secondary mb-0 max-w-xl">
          The Computer Science & Engineering Association is the official student body of the CS department at KITSW. We bridge the gap between academic theory and industry engineering.
        </p>
      </div>
      <div class="lg:col-span-5 reveal" style="transition-delay: 100ms;">
        <div class="aspect-[4/3] w-full bg-surface border border-border-strong rounded-2xl overflow-hidden shadow-medium p-3">
          <div class="img-placeholder w-full h-full rounded-xl">CSEA Representative Cover Photo</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Editorial layout: Core operations -->
  <section class="py-24 bg-surface">
    <div class="max-w-content mx-auto px-4 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Key Principles -->
      <div class="lg:col-span-7 reveal text-body text-foreground-secondary leading-relaxed flex flex-col gap-6">
        <h2 class="text-h2 text-foreground mb-2">Our Philosophy</h2>
        <p>
          CSEA operates as a technology incubator within the college. We do not just host seminars; we assemble teams to build internal software, we organize hackathons to test engineering endurance, and we maintain an active technical journal.
        </p>
        <p class="mb-6">
          Our core philosophy is <strong>"Structured Energy"</strong> — taking the raw enthusiasm of CS students and channeling it into precise, production-level outputs. We treat student projects with the same rigor as industry development pipelines.
        </p>

        <h3 class="text-h3 text-foreground mt-6 mb-2">Technical Publishing</h3>
        <p class="text-body-sm">
          Through the CSEA Journal, we document architectures, system decisions, and lessons learned by our student body. Writing is thinking, and clear documentation is a core engineering requirement.
        </p>

        <h3 class="text-h3 text-foreground mt-6 mb-2">Systems Engineering</h3>
        <p class="text-body-sm">
          We maintain CSEA's digital ecosystem, build automated lab tracking gateways, and ship open source utilities to assist the department. If a problem exists on campus, we build software to solve it.
        </p>
      </div>

      <!-- Right Column: Sidebar structural hierarchy -->
      <div class="lg:col-span-5 reveal flex flex-col gap-8" style="transition-delay: 100ms;">
        <div class="bg-canvas border border-border rounded-2xl p-6 lg:p-8">
          <div class="text-[10px] font-mono text-accent font-semibold tracking-wider uppercase mb-6">// ORGANIZATION HIERARCHY</div>
          
          <div class="flex flex-col gap-6 border-l-2 border-accent/20 pl-5">
            <div>
              <h4 class="font-semibold text-foreground text-[14.5px] leading-tight">Core Committee</h4>
              <p class="text-[12.5px] text-foreground-secondary mt-1">Final year students responsible for high-level strategy and technical direction.</p>
            </div>
            <div>
              <h4 class="font-semibold text-foreground text-[14.5px] leading-tight">Joint Executives</h4>
              <p class="text-[12.5px] text-foreground-secondary mt-1">Third year students managing operations, project delivery, and event logistics.</p>
            </div>
            <div>
              <h4 class="font-semibold text-foreground text-[14.5px] leading-tight">Executives</h4>
              <p class="text-[12.5px] text-foreground-secondary mt-1">Second year students assisting in execution and technical building.</p>
            </div>
          </div>
        </div>

        <!-- Callout block to Team page -->
        <div class="border border-dashed border-border-strong/80 rounded-2xl p-6 lg:p-8 text-center bg-surface-secondary/30">
          <h4 class="font-semibold text-foreground text-[15px] mb-2">Meet the people behind the platform</h4>
          <p class="text-[13px] text-foreground-secondary mb-6 leading-relaxed">
            See the full roster of core members, joint executives, and faculty advisors directing CSEA operations.
          </p>
          <a href="/team" class="btn btn-outline text-[12.5px] w-full">
            Meet the Core Team &rarr;
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>
