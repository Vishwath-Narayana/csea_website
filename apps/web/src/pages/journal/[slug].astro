---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';

let post = null;
try {
  const res = await fetch(`${API_URL}/api/v1/journal/${slug}`);
  if (res.ok) {
    const data = await res.json();
    post = data.data;
  }
} catch (e) {
  console.error("Failed to fetch journal post details", e);
}

if (!post) {
  return Astro.redirect('/404');
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
};
---

<Layout title={`${post.title} | CSEA`}>
  
  <article class="relative bg-canvas bg-grid-blueprint min-h-screen pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="15" y1="0" x2="85" y2="100" stroke="var(--accent)" stroke-width="0.3" stroke-dasharray="2 2" />
      </svg>
    </div>
    
    <div class="max-w-[720px] mx-auto px-4 relative z-10">
      
      <!-- Article Meta Eyebrow -->
      <div class="text-center reveal mb-8">
        <div class="inline-flex items-center gap-3 text-[12px] text-foreground-muted font-mono uppercase">
          <a href="/journal" class="hover:text-accent transition-colors no-underline">Journal</a>
          <span>/</span>
          <span class="text-accent font-semibold">{post.category || 'General'}</span>
          <span>/</span>
          <span>{formatDate(post.publishedAt || post.createdAt)}</span>
        </div>
      </div>

      <!-- Main Title & Lead Paragraph -->
      <header class="text-center reveal mb-16">
        <h1 class="text-display-md text-balance leading-tight text-foreground mb-6">
          {post.title}
        </h1>
        <p class="text-body-lg text-foreground-secondary leading-relaxed max-w-2xl mx-auto">
          {post.excerpt}
        </p>

        <div class="flex items-center justify-center gap-3 mt-10">
          <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/20 flex items-center justify-center text-xs font-bold text-accent select-none">
            {post.authorName ? post.authorName.substring(0, 2).toUpperCase() : 'TA'}
          </div>
          <div class="text-left leading-tight">
            <div class="text-[14px] font-bold text-foreground">{post.authorName || 'CSEA Team'}</div>
            <div class="text-[11.5px] text-foreground-muted">Author</div>
          </div>
        </div>
      </header>

      <!-- Hero Visual Blueprint -->
      <div class="reveal mb-16" style="transition-delay: 50ms;">
        <div class="w-full aspect-[21/9] rounded-lg overflow-hidden bg-surface border border-border p-3 shadow-soft">
          <!-- Styled visual cover -->
          <div class="w-full h-full rounded bg-gradient-to-tr from-accent/15 to-accent-blue/15 flex flex-col justify-between p-5 select-none font-mono text-[10px] text-foreground-secondary border border-accent/10">
            <div class="flex justify-between">
              <span>RE_DISPATCH // {post.category ? post.category.toUpperCase() : 'ARTICLE'}</span>
              <span>VER 1.0</span>
            </div>
            <div class="flex justify-center">
              <svg class="w-16 h-16 text-accent opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 17 17 22 12"></polyline></svg>
            </div>
            <div class="text-[9px] text-accent/80 font-bold uppercase truncate">
              {post.title}
            </div>
          </div>
        </div>
      </div>

      <!-- Rich Text Content -->
      <div class="text-body text-foreground-secondary leading-relaxed flex flex-col gap-6 reveal" style="transition-delay: 100ms;">
        <div class="prose prose-invert max-w-none text-foreground-secondary">
          {post.content ? (
            <div set:html={post.content} />
          ) : (
            <p>No content available.</p>
          )}
        </div>
      </div>

      <!-- Share Block -->
      <div class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4 reveal">
        <div class="text-[13px] text-foreground-muted font-mono">// SHARE THIS ARTICLE</div>
        <div class="flex items-center gap-3">
          <button 
            class="btn btn-outline text-[12.5px] px-5 py-2.5 rounded-md"
            onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied to clipboard!');"
          >
            Copy Article Link
          </button>
        </div>
      </div>

    </div>
  </article>

</Layout>
