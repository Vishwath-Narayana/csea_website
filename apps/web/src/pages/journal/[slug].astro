---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';

let post = null;
try {
  const res = await fetch(`${API_URL}/api/v1/journal/${slug}`);
  if (res.ok) {
    const data = await res.json();
    post = data.data;
  }
} catch (e) {
  console.error("Failed to fetch journal post details", e);
}

if (!post) {
  return Astro.redirect('/404');
}

// If post has google drive URL, redirect to it
if (post.googleDriveUrl) {
  return Astro.redirect(post.googleDriveUrl);
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
};
---

<Layout title={`${post.title} | Journal | CSEA`}>

  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="15" y1="0" x2="85" y2="100" stroke="var(--accent)" stroke-width="0.3" stroke-dasharray="2 2" />
      </svg>
    </div>

    <div class="max-w-[720px] mx-auto px-4 relative z-10">

      <!-- Breadcrumbs -->
      <div class="text-center reveal mb-8">
        <div class="inline-flex items-center gap-3 text-[12px] text-foreground-muted font-mono uppercase">
          <a href="/journal" class="hover:text-accent transition-colors no-underline">Journal</a>
          <span>/</span>
          <span class="text-accent font-semibold">{post.category || 'Report'}</span>
          <span>/</span>
          <span>{formatDate(post.publishedAt || post.createdAt)}</span>
        </div>
      </div>

      <!-- Header -->
      <header class="text-center reveal mb-12">
        <h1 class="text-display-md text-balance leading-tight text-foreground mb-4">
          {post.title}
        </h1>
        {post.excerpt && (
          <p class="text-body text-foreground-secondary leading-relaxed max-w-2xl mx-auto">
            {post.excerpt}
          </p>
        )}
      </header>

      <!-- Fallback Message (no google drive URL) -->
      <div class="reveal bg-surface border border-border rounded-lg p-8 text-center">
        <div class="mb-4">
          <svg class="w-12 h-12 text-foreground-muted/40 mx-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h2 class="text-h3 font-semibold text-foreground mb-2">Report Not Available</h2>
        <p class="text-body text-foreground-secondary mb-6">
          This journal entry does not have a linked report.
        </p>
        <a href="/journal" class="inline-block bg-accent text-foreground font-semibold px-6 py-2.5 rounded-lg hover:bg-accent/90 transition-colors no-underline">
          Back to Journal
        </a>
      </div>

    </div>
  </div>

</Layout>
