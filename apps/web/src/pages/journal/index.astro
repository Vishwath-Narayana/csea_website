---
import Layout from '../../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
let posts = [];
try {
  const res = await fetch(`${API_URL}/api/v1/journal`);
  if (res.ok) {
    const data = await res.json();
    posts = data.data || [];
  }
} catch (e) {
  console.error("Failed to fetch journal posts", e);
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
};
---

<Layout title="Journal | CSEA">

  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0,20 Q50,80 100,20" stroke="var(--accent)" stroke-width="0.3" fill="none" />
      </svg>
    </div>

    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">

      <!-- Header -->
      <div class="mb-16 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> Journal
        </div>
        <h1 class="text-display-lg mb-4 text-balance text-foreground">Reports and Updates.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Technical reports, event summaries, and project updates from CSEA builders.
        </p>
      </div>

      <!-- Journal Grid -->
      <div class="reveal" style="transition-delay: 100ms;">
        {posts.length === 0 ? (
          <div class="text-center py-20 text-foreground-secondary">
            <p>No journal entries published yet.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post: any) => (
              <div class="group bg-surface border border-border hover:border-accent/40 rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300 flex flex-col">
                <div class="flex-1 flex flex-col p-5">
                  <div class="flex items-center justify-between mb-3">
                    {post.category && (
                      <span class="text-[11px] font-mono text-accent font-bold tracking-wider uppercase">{post.category}</span>
                    )}
                    <span class="text-[12px] text-foreground-muted">{formatDate(post.publishedAt || post.createdAt)}</span>
                  </div>

                  <h3 class="text-h3 mb-2 leading-snug line-clamp-2">
                    {post.title}
                  </h3>

                  {post.excerpt && (
                    <p class="text-[13.5px] text-foreground-secondary leading-relaxed mb-4 flex-1 line-clamp-3">
                      {post.excerpt}
                    </p>
                  )}

                  <div class="border-t border-border pt-4 mt-auto">
                    {post.googleDriveUrl ? (
                      <a
                        href={post.googleDriveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center text-[12px] font-medium text-foreground group-hover:text-accent hover:text-accent transition-colors no-underline"
                      >
                        View Report →
                      </a>
                    ) : (
                      <span class="text-[12px] text-foreground-muted">No report available</span>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
