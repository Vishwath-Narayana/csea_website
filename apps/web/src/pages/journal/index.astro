---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="The Technical Journal | CSEA">
  
  <div class="bg-canvas bg-grid-blueprint min-h-screen relative pt-28 pb-32">
    <div class="absolute inset-0 pointer-events-none select-none opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0,20 Q50,80 100,20" stroke="var(--accent)" stroke-width="0.3" fill="none" />
      </svg>
    </div>
    
    <div class="max-w-[1400px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">
      
      <!-- Header block -->
      <div class="mb-16 reveal">
        <div class="text-[11px] font-mono text-accent font-bold tracking-widest uppercase mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span> // DISPATCHES & DOCUMENTATION
        </div>
        <h1 class="text-display-lg mb-4 text-balance text-foreground">The Journal.</h1>
        <p class="text-body-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Architectural breakdowns, event logs, and engineering articles written by CSEA developers and builders.
        </p>
      </div>

      <!-- Categories filter -->
      <div class="flex items-center gap-3 border-b border-border pb-6 mb-16 overflow-x-auto hide-scrollbar reveal" style="transition-delay: 50ms;">
        <span class="text-[11px] font-mono text-foreground-muted tracking-wider uppercase mr-4 whitespace-nowrap">// FILTER</span>
        <a href="#" class="text-[13px] font-semibold text-white bg-accent px-4 py-2 rounded-md whitespace-nowrap shadow-soft no-underline">All dispatches</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Technical</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Reports</a>
        <a href="#" class="text-[13px] font-medium text-foreground-secondary hover:text-foreground bg-surface border border-border px-4 py-2 rounded-md whitespace-nowrap transition-colors no-underline">Announcements</a>
      </div>

      <!-- Asymmetric Featured Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20 reveal" style="transition-delay: 100ms;">
        
        <!-- Large Left Featured Article Card -->
        <a href="/journal/tech-stack" class="lg:col-span-7 group no-underline text-foreground block">
          <div class="bg-surface border border-border rounded-lg p-4 shadow-soft hover:shadow-medium hover:border-accent/40 transition-all duration-300">
            <!-- Styled SVG editorial graphic -->
            <div class="w-full aspect-[16/10] rounded-md overflow-hidden bg-surface-secondary border border-border mb-6 relative select-none font-mono text-[10px] text-foreground-secondary flex flex-col justify-between p-6">
              <div class="flex justify-between items-start">
                <span>RE_DISPATCH // PLATFORM_STACK</span>
                <span>SYS_INIT</span>
              </div>
              <div class="flex justify-center">
                <svg class="w-16 h-16 text-accent opacity-20 group-hover:scale-105 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              </div>
              <div class="text-[9px] text-accent/80 font-bold">
                ASTRO &middot; REACT &middot; FASTIFY &middot; POSTGRES
              </div>
            </div>
            
            <div class="flex items-center gap-4 text-[12px] text-foreground-muted mb-3.5 font-mono">
              <span class="text-accent font-semibold uppercase tracking-wider">Technical</span>
              <span>Aug 12, 2026</span>
              <span>4 min read</span>
            </div>
            
            <h2 class="text-display-md group-hover:text-accent transition-colors leading-tight mb-4 text-foreground">
              Architecting the New CSEA Platform
            </h2>
            
            <p class="text-body text-foreground-secondary leading-relaxed mb-6">
              A deep dive into why we chose an Astro frontend, Fastify backend, and PostgreSQL database to power the next generation of our technical community infrastructure.
            </p>
            
            <div class="flex items-center gap-3 border-t border-border pt-4 mt-6">
              <div class="w-7 h-7 rounded-md bg-accent/5 border border-accent/20 flex items-center justify-center text-[10px] font-bold text-accent select-none">TA</div>
              <span class="text-[13.5px] font-bold text-foreground">Technical Architecture Team</span>
            </div>
          </div>
        </a>

        <!-- Right Side: Secondary Grid of Dispatches -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          
          <!-- Dispatch 2 -->
          <a href="/journal/orientation" class="group no-underline text-foreground bg-surface border border-border hover:border-accent/40 rounded-lg p-6 shadow-soft transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="badge bg-accent-muted text-accent font-semibold rounded-md border border-accent/15">Announcements</span>
              <span class="text-[11.5px] font-mono text-foreground-muted">Aug 05</span>
            </div>
            <h3 class="text-h3 mb-2 group-hover:text-accent transition-colors leading-snug">Registration Open for Orientation '26</h3>
            <p class="text-[13.5px] text-foreground-secondary leading-relaxed">
              Secure your spot for the opening ceremony of the academic year. Meet the committee and discover our roadmap.
            </p>
          </a>

          <!-- Dispatch 3 -->
          <a href="/journal/hackathon" class="group no-underline text-foreground bg-surface border border-border hover:border-accent/40 rounded-lg p-6 shadow-soft transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="badge bg-accent-muted text-accent font-semibold rounded-md border border-accent/15">Reports</span>
              <span class="text-[11.5px] font-mono text-foreground-muted">Jul 28</span>
            </div>
            <h3 class="text-h3 mb-2 group-hover:text-accent transition-colors leading-snug">Lessons from the Summer Hackathon</h3>
            <p class="text-[13.5px] text-foreground-secondary leading-relaxed">
              What we learned organizing a 48-hour continuous building session, tech stack reviews, and winning prototype submissions.
            </p>
          </a>

          <!-- Dispatch 4 -->
          <a href="#" class="group no-underline text-foreground bg-surface border border-border hover:border-accent/40 rounded-lg p-6 shadow-soft transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="badge bg-accent-muted text-accent font-semibold rounded-md border border-accent/15">Community</span>
              <span class="text-[11.5px] font-mono text-foreground-muted">Jul 10</span>
            </div>
            <h3 class="text-h3 mb-2 group-hover:text-accent transition-colors leading-snug">Connecting with the Class of 2024</h3>
            <p class="text-[13.5px] text-foreground-secondary leading-relaxed">
              Insights from our recent alumni panel on breaking into big tech and open-source contributions.
            </p>
          </a>

        </div>

      </div>

    </div>
  </div>

</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
