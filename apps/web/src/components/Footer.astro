---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-canvas text-dark-foreground border-t border-dark-border pt-16 pb-8 dark-env relative overflow-hidden">
  <div class="max-w-[1280px] mx-auto px-5 md:px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8 mb-12">
      
      <!-- Column 1: CSEA Identity and Description (span 4) -->
      <div class="lg:col-span-4">
        <a href="/" class="flex items-center gap-3 no-underline text-dark-foreground mb-6">
          <div class="flex items-center justify-center w-8 h-8 rounded-[8px] bg-accent text-white font-bold text-sm tracking-tighter">
            CS
          </div>
          <div class="flex flex-col">
            <span class="font-sans font-semibold text-[14px] tracking-tight leading-none">
              Computer Science & Engineering Association
            </span>
            <span class="text-[9px] font-medium tracking-[0.08em] text-dark-foreground-muted uppercase mt-1 leading-none">
              KITSW &middot; Department of CSE
            </span>
          </div>
        </a>
        <p class="text-[14px] leading-relaxed text-dark-foreground-muted max-w-[320px]">
          CSEA is the student-led software development, learning, and publishing body for Computer Science at Kakatiya Institute of Technology & Science, Warangal.
        </p>
      </div>

      <!-- Column 2: Explore Links (span 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-[11px] font-semibold text-dark-foreground tracking-[0.08em] uppercase mb-5 leading-none">// Explore</h4>
        <ul class="flex flex-col gap-3.5 list-none p-0 m-0 text-[13.5px]">
          <li><a href="/" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Home</a></li>
          <li><a href="/events" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Events Roadmap</a></li>
          <li><a href="/projects" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Student Builds</a></li>
          <li><a href="/gallery" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Moments Archive</a></li>
        </ul>
      </div>

      <!-- Column 3: Association Links (span 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-[11px] font-semibold text-dark-foreground tracking-[0.08em] uppercase mb-5 leading-none">// Association</h4>
        <ul class="flex flex-col gap-3.5 list-none p-0 m-0 text-[13.5px]">
          <li><a href="/about" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">About CSEA</a></li>
          <li><a href="/journal" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Technical Journal</a></li>
          <li><a href="/team" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Executive Team</a></li>
        </ul>
      </div>

      <!-- Column 4: Resources (span 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-[11px] font-semibold text-dark-foreground tracking-[0.08em] uppercase mb-5 leading-none">// Resources</h4>
        <ul class="flex flex-col gap-3.5 list-none p-0 m-0 text-[13.5px]">
          <li><a href="/portal/login" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">Student Portal</a></li>
          <li><a href="https://kitsw.ac.in" target="_blank" rel="noopener noreferrer" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline font-mono text-[12.5px]">kitsw.ac.in &rarr;</a></li>
          <li><a href="#" class="text-dark-foreground-muted hover:text-accent transition-colors no-underline">CSE Department</a></li>
        </ul>
      </div>

      <!-- Column 5: Contact details (span 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-[11px] font-semibold text-dark-foreground tracking-[0.08em] uppercase mb-5 leading-none">// Contact</h4>
        <p class="text-[13px] leading-relaxed text-dark-foreground-muted mb-4 font-sans">
          Block-II, KITSW Campus,<br/>
          Yerragattu Gutta, Warangal,<br/>
          Telangana — 560015
        </p>
        <div class="text-[13.5px] font-medium">
          <a href="mailto:csea@kitsw.ac.in" class="text-accent hover:underline no-underline">csea@kitsw.ac.in</a>
        </div>
      </div>

    </div>

    <!-- Bottom copyright and links -->
    <div class="pt-6 border-t border-dark-border flex flex-col md:flex-row justify-between items-center gap-4 relative z-10">
      <div class="text-[12.5px] text-dark-foreground-muted font-medium">
        &copy; {currentYear} Computer Science & Engineering Association, KITSW. All rights reserved.
      </div>
      <div class="flex items-center gap-6">
        <a href="#" class="text-[13px] text-dark-foreground-muted hover:text-accent transition-colors no-underline">Instagram</a>
        <a href="#" class="text-[13px] text-dark-foreground-muted hover:text-accent transition-colors no-underline">LinkedIn</a>
        <a href="https://github.com" class="text-[13px] text-dark-foreground-muted hover:text-accent transition-colors no-underline">GitHub</a>
      </div>
    </div>
  </div>

  <!-- Giant background branding text - partially cropped -->
  <div class="absolute bottom-[-15%] left-0 right-0 text-center select-none opacity-[0.015] pointer-events-none z-0 overflow-hidden">
    <div class="text-[18vw] font-bold tracking-tight uppercase leading-[0.7] font-sans translate-y-12">CSEA KITSW</div>
  </div>
</footer>
