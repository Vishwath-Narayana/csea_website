---
const { hasBanner = false } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Events', href: '/events' },
  { label: 'Projects', href: '/projects' },
  { label: 'Journal', href: '/journal' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Team', href: '/team' },
];
---

<header id="main-nav" class={`fixed top-0 inset-x-0 z-50 transition-all duration-500 pb-4 w-full ${hasBanner ? 'pt-16' : 'pt-6'}`} data-has-banner={hasBanner ? "true" : "false"}>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
    <div id="nav-container" class="h-16 rounded-xl border border-transparent bg-transparent px-5 flex items-center justify-between transition-all duration-300">
      
      <!-- LEFT: CSEA Official Brand Identity -->
      <a href="/" class="flex items-center gap-3 group no-underline text-foreground flex-shrink-0">
        <div class="flex items-center justify-center w-8 h-8 rounded-[8px] bg-accent text-white font-bold text-[14px] tracking-tighter flex-shrink-0 transition-transform group-hover:scale-105">
          CS
        </div>
        <div class="flex flex-col">
          <span class="font-sans font-semibold text-[14px] tracking-tight leading-none text-foreground group-hover:text-accent transition-colors">
            CSEA <span class="font-normal text-foreground-muted">KITSW</span>
          </span>
          <span class="text-[9px] font-medium tracking-[0.08em] text-foreground-muted uppercase mt-0.5 leading-none">
            Department of CSE
          </span>
        </div>
      </a>

      <!-- CENTER: Desktop Navigation Links -->
      <nav class="hidden lg:flex items-center gap-1 h-full relative">
        {navItems.map(item => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a 
              href={item.href} 
              class={`relative h-full px-4 flex items-center text-[14px] font-medium transition-colors hover:text-foreground
                ${isActive ? 'text-accent font-semibold' : 'text-foreground-secondary'}
              `}
            >
              <span>{item.label}</span>
              {isActive && (
                <div class="absolute bottom-0 inset-x-4 h-[3px] bg-accent rounded-t-sm opacity-90 transition-opacity"></div>
              )}
            </a>
          );
        })}
      </nav>

      <!-- RIGHT: Actions -->
      <div class="flex items-center gap-2 lg:gap-3 flex-shrink-0">
        
        <!-- Search link trigger -->
        <a 
          href="/search" 
          class="flex items-center justify-center p-2 rounded-lg text-foreground-secondary hover:text-foreground hover:bg-surface-secondary transition-all duration-200"
          aria-label="Search"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </a>



        <!-- Mobile Menu Toggle -->
        <button 
          id="mobile-menu-btn" 
          class="lg:hidden p-2 text-foreground-secondary hover:text-foreground focus:outline-none"
          aria-label="Toggle Menu"
        >
          <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div 
    id="mobile-menu" 
    class="fixed inset-x-0 top-[80px] bottom-0 bg-canvas/98 backdrop-blur-xl z-40 hidden flex-col border-t border-border transform transition-all duration-300 translate-x-full lg:hidden"
  >
    <div class="flex-1 overflow-y-auto px-6 py-8 flex flex-col justify-between">
      <nav class="flex flex-col gap-1">
        <div class="text-[10px] font-semibold text-foreground-muted tracking-widest uppercase mb-4 pl-3">// Navigation</div>
        {navItems.map(item => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a 
              href={item.href} 
              class={`flex items-center justify-between px-4 py-3.5 rounded-lg transition-all duration-200 no-underline
                ${isActive ? 'bg-accent/5 text-accent font-semibold' : 'text-foreground hover:bg-surface-secondary'}
              `}
            >
              <span class="text-[16px] tracking-tight">{item.label}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="opacity-45"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          );
        })}
      </nav>


    </div>
  </div>
</header>

<script>
  // Floating Navbar scroll interaction
  const mainNav = document.getElementById('main-nav');
  const navContainer = document.getElementById('nav-container');
  const mobileMenu = document.getElementById('mobile-menu');
  const hasBanner = mainNav?.getAttribute('data-has-banner') === 'true';

  function handleScroll() {
    const triggerOffset = hasBanner ? 48 : 24;
    if (window.scrollY > triggerOffset) {
      mainNav?.classList.remove('pt-16', 'pt-6', 'pb-4');
      mainNav?.classList.add('pt-3', 'pb-2');
      navContainer?.classList.remove('border-transparent', 'bg-transparent');
      navContainer?.classList.add('border-border', 'bg-surface/90', 'backdrop-blur-xl', 'shadow-soft');
      if (mobileMenu) {
        mobileMenu.style.top = '68px';
      }
    } else {
      mainNav?.classList.remove('pt-3', 'pb-2');
      mainNav?.classList.add(hasBanner ? 'pt-16' : 'pt-6', 'pb-4');
      navContainer?.classList.add('border-transparent', 'bg-transparent');
      navContainer?.classList.remove('border-border', 'bg-surface/90', 'backdrop-blur-xl', 'shadow-soft');
      if (mobileMenu) {
        mobileMenu.style.top = '80px';
      }
    }
  }

  window.addEventListener('scroll', handleScroll);
  handleScroll();

  // Mobile Menu Navigation Drawer Actions
  const menuBtn = document.getElementById('mobile-menu-btn');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (menuBtn && mobileMenu && iconOpen && iconClose) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('translate-x-full');
      
      if (isOpen) {
        mobileMenu.classList.add('translate-x-full');
        setTimeout(() => mobileMenu.classList.add('hidden'), 300);
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        mobileMenu.classList.remove('hidden');
        void mobileMenu.offsetWidth; // force reflow
        mobileMenu.classList.remove('translate-x-full');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    });
  }
</script>
